  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script>
    import { getProspect, saveProspect, mergeTransactions, generateId, savePDF, getPDF, getPDFWithText, clearAllPDFs } from '../lib/store';
    import type { Prospect, PageTextData } from '../lib/store';
    import { analyzeProspect, formatCurrency, formatDate, formatPeriod } from '../lib/analysis';
    import { detectBank, parseANZStatement, parseWestpacStatement, parseGenericStatement } from '../lib/pdfParser';
    import type { PageText } from '../lib/pdfParser';
    import { CATEGORY_COLORS, BENCHMARKS } from '../lib/categorize';

    // Get PDF.js from global (loaded via CDN above)
    const pdfjsLib = (window as any).pdfjsLib;
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    // Get prospect ID from URL
    const urlParams = new URLSearchParams(window.location.search);
    const prospectId = urlParams.get('id') || '';
    let prospect: Prospect | undefined = getProspect(prospectId);
    let currentPage = 1;
    const pageSize = 25;
    let selectedMonth = 'all'; // 'all' or 'YYYY-MM'
    let availableMonths: string[] = [];

    if (!prospect) {
      window.location.href = '/';
    }

    // Get unique months from transactions
    function getAvailableMonths(): string[] {
      if (!prospect) return [];
      const months = new Set<string>();
      for (const txn of prospect.transactions) {
        if (txn.date) {
          months.add(txn.date.substring(0, 7)); // YYYY-MM
        }
      }
      return Array.from(months).sort().reverse(); // Most recent first
    }

    // Filter transactions by selected month
    function getFilteredTransactions() {
      if (!prospect) return [];
      if (selectedMonth === 'all') return prospect.transactions;
      return prospect.transactions.filter(t => t.date?.startsWith(selectedMonth));
    }

    // Format month for display
    function formatMonth(monthStr: string): string {
      const [year, month] = monthStr.split('-');
      const date = new Date(parseInt(year), parseInt(month) - 1);
      return date.toLocaleDateString('en-NZ', { month: 'long', year: 'numeric' });
    }

    // Month selector
    const monthSelector = document.getElementById('month-selector') as HTMLSelectElement;
    const prevMonthBtn = document.getElementById('prev-month');
    const nextMonthBtn = document.getElementById('next-month');

    monthSelector?.addEventListener('change', () => {
      selectedMonth = monthSelector.value;
      currentPage = 1;
      renderAnalysis();
    });

    prevMonthBtn?.addEventListener('click', () => {
      const currentIndex = availableMonths.indexOf(selectedMonth);
      if (currentIndex < availableMonths.length - 1) {
        selectedMonth = availableMonths[currentIndex + 1];
        monthSelector.value = selectedMonth;
        currentPage = 1;
        renderAnalysis();
      }
    });

    nextMonthBtn?.addEventListener('click', () => {
      const currentIndex = availableMonths.indexOf(selectedMonth);
      if (currentIndex > 0) {
        selectedMonth = availableMonths[currentIndex - 1];
        monthSelector.value = selectedMonth;
        currentPage = 1;
        renderAnalysis();
      } else if (selectedMonth !== 'all' && currentIndex === 0) {
        selectedMonth = 'all';
        monthSelector.value = 'all';
        currentPage = 1;
        renderAnalysis();
      }
    });

    // Tab switching (Input mode)
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active', 'border-emerald-500', 'text-emerald-600');
          b.classList.add('border-transparent', 'text-slate-500');
        });
        btn.classList.add('active', 'border-emerald-500', 'text-emerald-600');
        btn.classList.remove('border-transparent', 'text-slate-500');

        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      });
    });

    // Output mode tab switching
    document.querySelectorAll('.output-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-output-tab');
        document.querySelectorAll('.output-tab-btn').forEach(b => {
          b.classList.remove('active', 'border-emerald-500', 'text-emerald-600');
          b.classList.add('border-transparent', 'text-slate-500');
        });
        btn.classList.add('active', 'border-emerald-500', 'text-emerald-600');
        btn.classList.remove('border-transparent', 'text-slate-500');

        document.querySelectorAll('.output-tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(`output-tab-${tab}`)?.classList.remove('hidden');
      });
    });

    // Mode switching (Input/Output)
    let currentMode = 'input';
    const modeInputBtn = document.getElementById('mode-input');
    const modeOutputBtn = document.getElementById('mode-output');
    const inputModeContainer = document.getElementById('input-mode');
    const outputModeContainer = document.getElementById('output-mode');

    function switchMode(mode: 'input' | 'output') {
      currentMode = mode;

      if (mode === 'input') {
        modeInputBtn?.classList.add('bg-white', 'text-emerald-600', 'shadow-sm');
        modeInputBtn?.classList.remove('text-slate-500');
        modeOutputBtn?.classList.remove('bg-white', 'text-emerald-600', 'shadow-sm');
        modeOutputBtn?.classList.add('text-slate-500');
        inputModeContainer?.classList.remove('hidden');
        outputModeContainer?.classList.add('hidden');
      } else {
        modeOutputBtn?.classList.add('bg-white', 'text-emerald-600', 'shadow-sm');
        modeOutputBtn?.classList.remove('text-slate-500');
        modeInputBtn?.classList.remove('bg-white', 'text-emerald-600', 'shadow-sm');
        modeInputBtn?.classList.add('text-slate-500');
        outputModeContainer?.classList.remove('hidden');
        inputModeContainer?.classList.add('hidden');

        // Render output mode content
        renderAverageExpense();
        renderApplicationSummary();
        renderLog();
      }
    }

    modeInputBtn?.addEventListener('click', () => switchMode('input'));
    modeOutputBtn?.addEventListener('click', () => switchMode('output'));

    // Expenses only toggle
    let expensesOnly = true;
    const expensesToggle = document.getElementById('expenses-only') as HTMLInputElement;

    function applyExpensesFilter() {
      const incomeSections = document.querySelectorAll('.income-section');
      const summaryCards = document.getElementById('summary-cards');
      const overviewGrid = document.getElementById('overview-grid');

      incomeSections.forEach(el => {
        if (expensesOnly) {
          el.classList.add('hidden');
        } else {
          el.classList.remove('hidden');
        }
      });

      // Adjust grid columns when hiding income cards
      if (summaryCards) {
        if (expensesOnly) {
          summaryCards.classList.remove('lg:grid-cols-4');
          summaryCards.classList.add('lg:grid-cols-2');
        } else {
          summaryCards.classList.remove('lg:grid-cols-2');
          summaryCards.classList.add('lg:grid-cols-4');
        }
      }

      // Make key indicators full width when money in is hidden
      if (overviewGrid) {
        if (expensesOnly) {
          overviewGrid.classList.remove('lg:grid-cols-2');
          overviewGrid.classList.add('lg:grid-cols-1');
        } else {
          overviewGrid.classList.remove('lg:grid-cols-1');
          overviewGrid.classList.add('lg:grid-cols-2');
        }
      }

      // Hide income in associated accounts
      document.querySelectorAll('.assoc-income').forEach(el => {
        (el as HTMLElement).style.display = expensesOnly ? 'none' : '';
      });
    }

    expensesToggle?.addEventListener('change', () => {
      expensesOnly = expensesToggle.checked;
      applyExpensesFilter();
    });

    // Apply on load
    applyExpensesFilter();

    // Associated accounts toggle
    let associatedExpanded = false;
    document.getElementById('toggle-associated')?.addEventListener('click', () => {
      associatedExpanded = !associatedExpanded;
      const hiddenSection = document.getElementById('associated-accounts-hidden');
      const toggleText = document.getElementById('toggle-associated-text');
      const toggleIcon = document.getElementById('toggle-associated-icon');

      if (associatedExpanded) {
        hiddenSection?.classList.remove('hidden');
        if (toggleText) toggleText.textContent = 'Hide';
        toggleIcon?.classList.add('rotate-180');
      } else {
        hiddenSection?.classList.add('hidden');
        const count = hiddenSection?.children.length || 0;
        if (toggleText) toggleText.textContent = `Show ${count} more (< $1,000)`;
        toggleIcon?.classList.remove('rotate-180');
      }
    });

    // PDF Upload handling
    document.querySelectorAll('#pdf-upload, .pdf-upload-trigger').forEach(input => {
      input.addEventListener('change', async (e) => {
        const files = (e.target as HTMLInputElement).files;
        if (!files || files.length === 0 || !prospect) return;

        const progressEl = document.getElementById('upload-progress');
        const statusEl = document.getElementById('upload-status');
        const detailEl = document.getElementById('upload-detail');
        const countEl = document.getElementById('upload-count');
        const progressFill = document.getElementById('upload-progress-fill');

        progressEl?.classList.remove('hidden');
        const fileArray = Array.from(files);
        const total = fileArray.length;
        let processed = 0;
        let totalTxns = 0;

        for (const file of fileArray) {
          processed++;
          if (statusEl) statusEl.textContent = `Processing ${file.name}`;
          if (detailEl) detailEl.textContent = 'Reading PDF...';
          if (countEl) countEl.textContent = `${processed} of ${total}`;
          if (progressFill) progressFill.style.width = `${(processed / total) * 100}%`;

          const txnCount = await processPDF(file, (stage: string) => {
            if (detailEl) detailEl.textContent = stage;
          });
          totalTxns += txnCount;
        }

        console.log('Upload complete. Total transactions:', totalTxns, 'Prospect transactions:', prospect.transactions.length);

        if (totalTxns > 0) {
          if (statusEl) statusEl.textContent = 'Complete!';
          if (detailEl) detailEl.textContent = `Imported ${totalTxns} transactions from ${total} file${total > 1 ? 's' : ''}`;
        } else {
          if (statusEl) statusEl.textContent = 'No transactions found';
          if (detailEl) detailEl.textContent = `Could not extract transactions from ${total} file${total > 1 ? 's' : ''}. Check the PDF format.`;
        }

        // Keep visible longer if no transactions
        setTimeout(() => {
          progressEl?.classList.add('hidden');
          if (progressFill) progressFill.style.width = '0%';
        }, totalTxns > 0 ? 1500 : 3000);

        (e.target as HTMLInputElement).value = '';
        renderAnalysis();
        console.log('After renderAnalysis. Prospect:', prospect);
      });
    });

    async function processPDF(file: File, onProgress?: (stage: string) => void): Promise<number> {
      if (!prospect) return 0;

      try {
        console.log('Processing PDF:', file.name);
        onProgress?.('Loading file...');
        const arrayBuffer = await file.arrayBuffer();
        console.log('Got array buffer, size:', arrayBuffer.byteLength);

        // Clone the ArrayBuffer before PDF.js uses it (PDF.js may detach the original)
        const arrayBufferCopy = arrayBuffer.slice(0);

        // Generate document ID upfront
        const documentId = generateId();

        onProgress?.('Opening PDF...');
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        console.log('PDF loaded, pages:', pdf.numPages);

        let fullText = '';
        const pageTexts: PageText[] = [];

        for (let i = 1; i <= pdf.numPages; i++) {
          onProgress?.(`Extracting page ${i} of ${pdf.numPages}...`);
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          const pageText = textContent.items.map((item: any) => item.str).join(' ');
          fullText += pageText + '\n';
          pageTexts.push({ pageNumber: i, text: pageText });
        }
        console.log('Text extracted, length:', fullText.length);

        // Save PDF to IndexedDB with text content for searching
        onProgress?.('Saving document...');
        await savePDF(documentId, arrayBufferCopy, pageTexts);

        onProgress?.('Detecting bank format...');
        const bank = detectBank(fullText);
        console.log('Detected bank:', bank);

        onProgress?.('Parsing transactions...');
        let result;

        switch (bank) {
          case 'ANZ':
            result = parseANZStatement(fullText, file.name, documentId, pageTexts);
            break;
          case 'Westpac':
            result = parseWestpacStatement(fullText, file.name, documentId, pageTexts);
            break;
          default:
            result = parseGenericStatement(fullText, file.name, bank, documentId, pageTexts);
        }

        // Override the document ID with our pre-generated one
        result.document.id = documentId;

        console.log('Parsed result:', {
          transactions: result.transactions.length,
          accounts: result.accounts.length,
          document: result.document
        });

        if (result.transactions.length === 0) {
          console.warn('No transactions parsed! First 1000 chars of text:', fullText.substring(0, 1000));
        } else {
          console.log('Sample transactions:', result.transactions.slice(0, 3));
        }

        // Merge transactions
        prospect.transactions = mergeTransactions(prospect.transactions, result.transactions);

        // Add accounts (avoid duplicates)
        for (const account of result.accounts) {
          if (!prospect.accounts.find(a => a.number === account.number)) {
            prospect.accounts.push(account);
          }
        }

        // Add document
        result.document.pageCount = pdf.numPages;
        prospect.documents.push(result.document);

        saveProspect(prospect);
        return result.transactions.length;

      } catch (error: any) {
        console.error('Error processing PDF:', error);
        console.error('Error stack:', error?.stack);
        console.error('Error message:', error?.message);

        // If it's a deserialization error, clear corrupted IndexedDB data
        if (error?.message?.includes('deserialize')) {
          console.log('Clearing corrupted IndexedDB data...');
          try {
            await clearAllPDFs();
            alert(`Database cleared. Please try uploading ${file.name} again.`);
          } catch (e) {
            console.error('Error clearing database:', e);
            alert(`Error processing ${file.name}. Please clear your browser data and try again.`);
          }
        } else {
          alert(`Error processing ${file.name}: ${error?.message || 'Unknown error'}. Check console for details.`);
        }
        return 0;
      }
    }

    function renderAnalysis() {
      if (!prospect) return;

      // Update header
      document.getElementById('prospect-name')!.textContent = prospect.name;

      if (prospect.transactions.length === 0) {
        document.getElementById('no-data')?.classList.remove('hidden');
        document.getElementById('analysis-content')?.classList.add('hidden');
        document.getElementById('prospect-period')!.textContent = 'No statements uploaded';
        return;
      }

      document.getElementById('no-data')?.classList.add('hidden');
      document.getElementById('analysis-content')?.classList.remove('hidden');

      // Update month selector
      availableMonths = getAvailableMonths();
      const monthSelector = document.getElementById('month-selector') as HTMLSelectElement;
      if (monthSelector) {
        const currentValue = monthSelector.value;
        monthSelector.innerHTML = '<option value="all">All Months (' + availableMonths.length + ')</option>' +
          availableMonths.map(m => `<option value="${m}">${formatMonth(m)}</option>`).join('');
        // Restore selection if still valid
        if (currentValue === 'all' || availableMonths.includes(currentValue)) {
          monthSelector.value = currentValue;
          selectedMonth = currentValue;
        }
      }

      // Update nav buttons
      const currentIndex = availableMonths.indexOf(selectedMonth);
      const prevBtn = document.getElementById('prev-month') as HTMLButtonElement;
      const nextBtn = document.getElementById('next-month') as HTMLButtonElement;
      if (prevBtn) prevBtn.disabled = selectedMonth === 'all' || currentIndex >= availableMonths.length - 1;
      if (nextBtn) nextBtn.disabled = selectedMonth === 'all';

      // Get filtered transactions for this month
      const filteredTxns = getFilteredTransactions();

      // Calculate totals for filtered transactions (exclude transfers from expenses)
      const moneyIn = filteredTxns.filter(t => t.amount > 0 && !t.isTransfer).reduce((sum, t) => sum + t.amount, 0);
      const moneyOut = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer).reduce((sum, t) => sum + Math.abs(t.amount), 0);
      const expenseTxnCount = filteredTxns.filter(t => !t.isTransfer).length;

      const analysis = analyzeProspect(prospect);

      // Update period display
      if (selectedMonth === 'all') {
        document.getElementById('prospect-period')!.textContent = formatPeriod(analysis.period.start, analysis.period.end);
      } else {
        document.getElementById('prospect-period')!.textContent = formatMonth(selectedMonth);
      }

      // Summary cards - use filtered values
      document.getElementById('total-in')!.textContent = formatCurrency(moneyIn);
      if (selectedMonth === 'all') {
        document.getElementById('monthly-in')!.textContent = `${formatCurrency(moneyIn / analysis.period.months)}/month avg`;
      } else {
        document.getElementById('monthly-in')!.textContent = 'this month';
      }

      document.getElementById('total-out')!.textContent = formatCurrency(moneyOut);
      const monthlyOutEl = document.getElementById('monthly-out')!;
      if (selectedMonth === 'all' && analysis.period.months > 1) {
        monthlyOutEl.textContent = `(${formatCurrency(moneyOut / analysis.period.months)}/mo avg)`;
        monthlyOutEl.classList.remove('hidden');
      } else {
        monthlyOutEl.classList.add('hidden');
      }

      const net = moneyIn - moneyOut;
      const netEl = document.getElementById('net-position')!;
      netEl.textContent = formatCurrency(net, true);
      netEl.className = `text-2xl font-bold ${net >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      if (selectedMonth === 'all') {
        document.getElementById('net-monthly')!.textContent = `${formatCurrency(net / analysis.period.months, true)}/month avg`;
      } else {
        document.getElementById('net-monthly')!.textContent = 'this month';
      }

      document.getElementById('doc-count')!.textContent = prospect.documents.length.toString();
      document.getElementById('txn-count')!.textContent = `${expenseTxnCount} txns`;

      // Money In section
      document.getElementById('salary-total')!.textContent = formatCurrency(analysis.moneyInSummary.salary.total);
      document.getElementById('salary-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.salary.monthly)}/mo)`;
      document.getElementById('govt-total')!.textContent = formatCurrency(analysis.moneyInSummary.governmentSupport.total);
      document.getElementById('govt-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.governmentSupport.monthly)}/mo)`;
      document.getElementById('other-in-total')!.textContent = formatCurrency(analysis.moneyInSummary.otherMoneyIn.total);
      document.getElementById('other-in-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.otherMoneyIn.monthly)}/mo)`;

      // Key Indicators
      const indicators = [
        { name: 'ATM Withdrawals', data: analysis.keyIndicators.atmWithdrawals },
        { name: 'Debt Repayment', data: analysis.keyIndicators.debtRepayment },
        { name: 'Dishonours', data: analysis.keyIndicators.dishonours, isWarning: true },
        { name: 'Fees', data: analysis.keyIndicators.fees },
        { name: 'Gambling', data: analysis.keyIndicators.gambling, isWarning: true },
      ];

      document.getElementById('key-indicators')!.innerHTML = indicators.map(ind => `
        <div class="flex justify-between items-center py-2 border-b border-slate-100 ${ind.isWarning && ind.data.count > 0 ? 'bg-rose-50 -mx-2 px-2 rounded' : ''}">
          <span class="text-slate-600 ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700 font-medium' : ''}">${ind.name}</span>
          <div class="text-right">
            <span class="font-medium ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700' : 'text-slate-700'}">${ind.data.count}</span>
            <span class="text-xs text-slate-400 ml-2">${formatCurrency(ind.data.total)}</span>
          </div>
        </div>
      `).join('');

      // Associated Accounts
      const significantAccounts = analysis.associatedAccounts.filter(a => a.totalAmount >= 1000);
      const minorAccounts = analysis.associatedAccounts.filter(a => a.totalAmount < 1000);

      if (analysis.associatedAccounts.length > 0) {
        document.getElementById('no-accounts')?.classList.add('hidden');

        const renderAccountRow = (acc: typeof analysis.associatedAccounts[0]) => `
          <div class="flex items-center justify-between py-3 px-4 bg-slate-50 rounded-lg border border-slate-100 hover:border-blue-200 transition-colors">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span class="font-medium text-slate-800 truncate">${acc.name}</span>
              ${acc.accountNumber ? `<span class="text-slate-500 font-mono">${acc.accountNumber}</span>` : ''}
            </div>
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-4">
                ${acc.moneyIn > 0 ? `<span class="assoc-income text-emerald-600 font-medium">+${formatCurrency(acc.moneyIn)}</span>` : ''}
                ${acc.moneyOut > 0 ? `<span class="text-rose-600 font-medium">-${formatCurrency(acc.moneyOut)}</span>` : ''}
              </div>
              <span class="text-slate-400 w-16 text-right">${acc.transactionCount} txn${acc.transactionCount !== 1 ? 's' : ''}</span>
            </div>
          </div>
        `;

        document.getElementById('associated-accounts-list')!.innerHTML = significantAccounts.map(renderAccountRow).join('');

        if (minorAccounts.length > 0) {
          document.getElementById('associated-accounts-hidden')!.innerHTML = minorAccounts.map(renderAccountRow).join('');
          document.getElementById('toggle-associated')!.classList.remove('hidden');
          (document.getElementById('toggle-associated-text') as HTMLElement).textContent = `Show ${minorAccounts.length} more (< $1,000)`;
        } else {
          document.getElementById('toggle-associated')!.classList.add('hidden');
        }
      } else {
        document.getElementById('no-accounts')?.classList.remove('hidden');
        document.getElementById('associated-accounts-list')!.innerHTML = '';
        document.getElementById('toggle-associated')!.classList.add('hidden');
      }

      // Attention items
      renderAttention(analysis);

      // Categories
      renderCategories(analysis);

      // Transactions
      renderTransactions();

      // Documents
      renderDocuments();

      // Transfers
      renderTransfers();

      // Log
      renderLog();

      // Reapply expenses filter after rendering
      applyExpensesFilter();
    }

    function renderCategories(analysis: ReturnType<typeof analyzeProspect>) {
      const grid = document.getElementById('categories-grid')!;

      // Get month-filtered transactions
      const filteredTxns = getFilteredTransactions();

      // Build categories from filtered transactions
      const categoryMap = new Map<string, { total: number; count: number; transactions: typeof filteredTxns }>();

      for (const txn of filteredTxns) {
        // Use "Account Transfers" category for transfers, otherwise use original category
        const catName = txn.isTransfer ? 'Account Transfers' : txn.category;

        // Skip income transactions if expenses only mode (but include transfers)
        if (expensesOnly && !txn.isTransfer && txn.amount > 0) continue;

        if (!categoryMap.has(catName)) {
          categoryMap.set(catName, { total: 0, count: 0, transactions: [] });
        }
        const cat = categoryMap.get(catName)!;
        cat.total += Math.abs(txn.amount);
        cat.count++;
        cat.transactions.push(txn);
      }

      // Convert to array and sort by total
      const categories = Array.from(categoryMap.entries())
        .map(([name, data]) => ({
          category: name,
          total: data.total,
          transactionCount: data.count,
          transactions: data.transactions
        }))
        .filter(c => c.transactionCount > 0)
        .sort((a, b) => b.total - a.total);

      // Add color for Account Transfers
      const TRANSFER_COLOR = '#6366f1'; // Indigo

      grid.innerHTML = categories.map(cat => {
        const color = cat.category === 'Account Transfers' ? TRANSFER_COLOR : (CATEGORY_COLORS[cat.category] || '#94a3b8');
        const benchmark = BENCHMARKS[cat.category];
        let benchmarkIndicator = '';

        if (benchmark && cat.category !== 'Account Transfers') {
          const monthlyAvg = selectedMonth === 'all' ? cat.total / (analysis.period.months || 1) : cat.total;
          if (monthlyAvg > benchmark.high) {
            benchmarkIndicator = `<span class="text-xs text-rose-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
              Above avg
            </span>`;
          } else if (monthlyAvg < benchmark.low) {
            benchmarkIndicator = `<span class="text-xs text-emerald-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Below avg
            </span>`;
          }
        }

        const monthlyAvg = selectedMonth === 'all' ? cat.total / (analysis.period.months || 1) : cat.total;
        const isTransferCat = cat.category === 'Account Transfers';

        return `
          <button onclick="showCategoryDetail('${cat.category}')" class="bg-slate-50 hover:bg-slate-100 rounded-lg p-4 text-left transition-colors group ${isTransferCat ? 'border-2 border-dashed border-indigo-200' : ''}">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full" style="background-color: ${color}"></div>
                <span class="font-medium text-slate-700 group-hover:text-emerald-600 transition-colors">${cat.category}</span>
              </div>
              <span class="text-xs text-slate-400">${cat.transactionCount} txns</span>
            </div>
            <div class="flex items-end justify-between">
              <div>
                <p class="text-lg font-semibold ${isTransferCat ? 'text-indigo-600' : 'text-slate-900'}">${formatCurrency(cat.total)}</p>
                ${selectedMonth === 'all' ? `<p class="text-xs text-slate-500">${formatCurrency(monthlyAvg)}/month</p>` : ''}
              </div>
              ${benchmarkIndicator}
            </div>
          </button>
        `;
      }).join('');
    }

    function renderAttention(analysis: ReturnType<typeof analyzeProspect>) {
      if (!prospect) return;

      const transferIds = new Set(prospect.transactions.filter(t => t.isTransfer).map(t => t.id));

      // Get transaction IDs in selected date range
      const filteredTxnIds = new Set(getFilteredTransactions().map(t => t.id));

      const attentionItems = analysis.anomalies
        .filter(a => a.severity === 'high' || a.severity === 'medium')
        .filter(a => !a.transactionId || !transferIds.has(a.transactionId))
        .filter(a => {
          // If no transactionId (category-level anomaly), only show when viewing all data
          if (!a.transactionId) return selectedMonth === 'all';
          // If has transactionId, only show if transaction is in selected date range
          return filteredTxnIds.has(a.transactionId);
        });

      if (attentionItems.length > 0) {
        document.getElementById('no-attention')?.classList.add('hidden');
        document.getElementById('attention-list')!.innerHTML = attentionItems.map(a => {
          const txn = a.transactionId ? prospect.transactions.find(t => t.id === a.transactionId) : null;
          return `
            <div class="p-4 bg-amber-50 border border-amber-200 rounded-lg ${txn ? 'cursor-pointer hover:bg-amber-100 transition-colors' : ''}" ${txn ? `onclick="showAttentionTransaction('${a.transactionId}')"` : ''}>
              <div class="flex items-start gap-3">
                <span class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${a.severity === 'high' ? 'bg-rose-500' : 'bg-amber-500'}"></span>
                <div class="flex-1">
                  <p class="text-slate-800">${a.reason}</p>
                  ${a.suggestion ? `<p class="text-amber-600 text-sm mt-1">${a.suggestion}</p>` : ''}
                  ${txn ? `
                    <div class="mt-3 pt-3 border-t border-amber-200">
                      <div class="flex items-center justify-between text-sm">
                        <div>
                          <span class="text-slate-500">${formatDate(txn.date)}</span>
                          <span class="mx-2 text-slate-300">|</span>
                          <span class="text-slate-700">${txn.description}</span>
                        </div>
                        <span class="font-medium ${txn.amount < 0 ? 'text-rose-600' : 'text-emerald-600'}">${formatCurrency(Math.abs(txn.amount))}</span>
                      </div>
                      <p class="text-xs text-slate-400 mt-1">${txn.category} • Click to view options</p>
                    </div>
                  ` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');
      } else {
        document.getElementById('attention-list')!.innerHTML = '';
        document.getElementById('no-attention')?.classList.remove('hidden');
      }
    }

    function renderTransactions() {
      if (!prospect) return;

      const search = (document.getElementById('txn-search') as HTMLInputElement).value.toLowerCase();
      const categoryFilter = (document.getElementById('txn-category-filter') as HTMLSelectElement).value;

      // Start with month-filtered transactions
      let filtered = getFilteredTransactions();

      // Filter out transfers
      filtered = filtered.filter(t => !t.isTransfer);

      // Filter out income if expenses only mode
      if (expensesOnly) {
        filtered = filtered.filter(t => t.amount < 0);
      }

      if (search) {
        filtered = filtered.filter(t => t.description.toLowerCase().includes(search) || (t.rawDescription || '').toLowerCase().includes(search));
      }

      if (categoryFilter) {
        filtered = filtered.filter(t => t.category === categoryFilter);
      }

      const totalPages = Math.ceil(filtered.length / pageSize);
      const start = (currentPage - 1) * pageSize;
      const paginated = filtered.slice(start, start + pageSize);

      const tbody = document.getElementById('transactions-table')!;
      tbody.innerHTML = paginated.map(txn => `
        <tr class="border-b border-slate-100 hover:bg-slate-50 group">
          <td class="py-3 text-slate-600 whitespace-nowrap">${formatDate(txn.date)}</td>
          <td class="py-3">
            <p class="text-slate-900">${txn.description}</p>
            ${txn.isAnomalous ? `<p class="text-xs text-amber-600">${txn.anomalyReason}</p>` : ''}
            ${txn.note ? `<p class="text-xs text-purple-600 mt-1 flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>${txn.note}</p>` : ''}
          </td>
          <td class="py-3">
            <span class="px-2 py-1 rounded text-xs font-medium whitespace-nowrap" style="background-color: ${CATEGORY_COLORS[txn.category]}20; color: ${CATEGORY_COLORS[txn.category]}">${txn.category}</span>
          </td>
          <td class="py-3 text-right font-medium whitespace-nowrap ${txn.amount >= 0 ? 'text-emerald-600' : 'text-rose-600'}">${formatCurrency(txn.amount, true)}</td>
          <td class="py-3 text-center">
            <button onclick="openNoteModal('${txn.id}')" class="text-xs px-2 py-1 rounded border ${txn.note ? 'border-purple-200 bg-purple-50 text-purple-600' : 'border-slate-200 hover:bg-purple-50 hover:border-purple-200 hover:text-purple-600'} transition-colors ${txn.note ? '' : 'opacity-0 group-hover:opacity-100'}" title="${txn.note ? 'Edit note' : 'Add note'}">
              <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
              </svg>
            </button>
          </td>
          <td class="py-3 text-center">
            ${txn.documentId ? `
              <button onclick="showPdfDetail('${txn.id}')" class="text-xs px-2 py-1 rounded border border-slate-200 hover:bg-emerald-50 hover:border-emerald-300 hover:text-emerald-600 transition-colors opacity-0 group-hover:opacity-100" title="View in document">
                <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            ` : ''}
          </td>
          <td class="py-3 text-center">
            <button onclick="markAsTransfer('${txn.id}')" class="text-xs px-2 py-1 rounded border border-slate-200 hover:bg-blue-50 hover:border-blue-200 hover:text-blue-600 transition-colors opacity-0 group-hover:opacity-100" title="Mark as account transfer">
              <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </button>
          </td>
        </tr>
      `).join('');

      // Populate category filter
      const categories = [...new Set(prospect.transactions.map(t => t.category))].sort();
      const filter = document.getElementById('txn-category-filter') as HTMLSelectElement;
      const currentValue = filter.value;
      filter.innerHTML = '<option value="">All Categories</option>' + categories.map(c => `<option value="${c}" ${c === currentValue ? 'selected' : ''}>${c}</option>`).join('');

      // Pagination
      const pagination = document.getElementById('txn-pagination')!;
      if (totalPages > 1) {
        pagination.innerHTML = `
          <button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="px-3 py-1 rounded border ${currentPage === 1 ? 'text-slate-300 border-slate-200' : 'text-slate-600 border-slate-300 hover:bg-slate-50'}">Prev</button>
          <span class="px-3 py-1 text-slate-600">Page ${currentPage} of ${totalPages}</span>
          <button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="px-3 py-1 rounded border ${currentPage === totalPages ? 'text-slate-300 border-slate-200' : 'text-slate-600 border-slate-300 hover:bg-slate-50'}">Next</button>
        `;
      } else {
        pagination.innerHTML = '';
      }
    }

    function renderDocuments() {
      if (!prospect) return;

      const list = document.getElementById('documents-list')!;

      if (prospect.documents.length === 0) {
        list.innerHTML = '<p class="text-slate-500 text-center py-8">No documents uploaded yet</p>';
        return;
      }

      list.innerHTML = prospect.documents.map(doc => `
        <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-rose-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="min-w-0">
              <p class="font-medium text-slate-700 truncate">${doc.filename}</p>
              <p class="text-xs text-slate-500">${doc.bank} &bull; ${doc.pageCount || '?'} pages &bull; Uploaded ${formatDate(doc.uploadedAt)}</p>
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderTransfers() {
      if (!prospect) return;

      const transfers = prospect.transactions.filter(t => t.isTransfer);
      const tbody = document.getElementById('transfers-table')!;
      const noTransfers = document.getElementById('no-transfers')!;

      if (transfers.length === 0) {
        tbody.innerHTML = '';
        noTransfers.classList.remove('hidden');
        return;
      }

      noTransfers.classList.add('hidden');
      tbody.innerHTML = transfers.map(txn => `
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="py-3 text-slate-600 whitespace-nowrap">${formatDate(txn.date)}</td>
          <td class="py-3">
            <p class="text-slate-900">${txn.description}</p>
          </td>
          <td class="py-3 text-right font-medium whitespace-nowrap ${txn.amount >= 0 ? 'text-emerald-600' : 'text-rose-600'}">${formatCurrency(txn.amount, true)}</td>
          <td class="py-3 text-center">
            <button onclick="unmarkAsTransfer('${txn.id}')" class="text-xs px-2 py-1 rounded border border-blue-200 bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Remove from transfers">
              <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Remove
            </button>
          </td>
        </tr>
      `).join('');
    }

    // Mark transaction as transfer
    (window as any).markAsTransfer = (id: string) => {
      if (!prospect) return;

      const txn = prospect.transactions.find(t => t.id === id);
      if (txn) {
        txn.isTransfer = true;
        txn.transferMarkedAt = new Date().toISOString();
        saveProspect(prospect);
        const analysis = analyzeProspect(prospect);
        renderTransactions();
        renderTransfers();
        renderCategories(analysis);
        renderAttention(analysis);
        renderLog();
      }
    };

    // Unmark transaction as transfer
    (window as any).unmarkAsTransfer = (id: string) => {
      if (!prospect) return;

      const txn = prospect.transactions.find(t => t.id === id);
      if (txn) {
        txn.isTransfer = false;
        txn.transferMarkedAt = undefined;
        saveProspect(prospect);
        const analysis = analyzeProspect(prospect);
        renderTransactions();
        renderTransfers();
        renderCategories(analysis);
        renderAttention(analysis);
        renderLog();
      }
    };

    // Show attention transaction options
    (window as any).showAttentionTransaction = (id: string) => {
      if (!prospect) return;

      const txn = prospect.transactions.find(t => t.id === id);
      if (!txn) return;

      // Show options modal
      const modal = document.getElementById('attention-modal');
      if (!modal) return;

      document.getElementById('attention-modal-date')!.textContent = formatDate(txn.date);
      document.getElementById('attention-modal-desc')!.textContent = txn.description;
      document.getElementById('attention-modal-raw')!.textContent = txn.rawDescription || txn.description;
      document.getElementById('attention-modal-amount')!.textContent = formatCurrency(Math.abs(txn.amount));
      document.getElementById('attention-modal-amount')!.className = `text-xl font-bold ${txn.amount < 0 ? 'text-rose-600' : 'text-emerald-600'}`;
      document.getElementById('attention-modal-category')!.textContent = txn.category;
      document.getElementById('attention-modal-source')!.textContent = txn.source || 'Unknown';

      // Set up action buttons
      const viewDocBtn = document.getElementById('attention-view-doc') as HTMLButtonElement;
      const addNoteBtn = document.getElementById('attention-add-note') as HTMLButtonElement;
      const markTransferBtn = document.getElementById('attention-mark-transfer') as HTMLButtonElement;

      if (txn.documentId) {
        viewDocBtn.classList.remove('hidden');
        viewDocBtn.onclick = () => {
          modal.classList.add('hidden');
          (window as any).viewInDocument(id);
        };
      } else {
        viewDocBtn.classList.add('hidden');
      }

      addNoteBtn.onclick = () => {
        modal.classList.add('hidden');
        (window as any).openNoteModal(id);
      };

      markTransferBtn.onclick = () => {
        modal.classList.add('hidden');
        (window as any).markAsTransfer(id);
      };

      modal.classList.remove('hidden');
    };

