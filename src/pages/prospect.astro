  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script>
    import { mergeTransactions, generateId, savePDF, getPDF, getPDFWithText, clearAllPDFs, r2GetProspect, r2SaveProspect, r2SavePDF, r2GetPDF } from '../lib/store';
    import type { Prospect, PageTextData } from '../lib/store';
    import { analyzeProspect, formatCurrency, formatDate, formatPeriod } from '../lib/analysis';
    import { detectBank, parseANZStatement, parseASBStatement, parseWestpacStatement, parseGenericStatement } from '../lib/pdfParser';
    import type { PageText } from '../lib/pdfParser';
    import { CATEGORY_COLORS, BENCHMARKS } from '../lib/categorize';
    import { hasPassword, r2Get } from '../lib/r2';

    // Check auth on load
    if (!hasPassword()) {
      window.location.href = '/';
    }

    // Get PDF.js from global (loaded via CDN above)
    const pdfjsLib = (window as any).pdfjsLib;
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    // Get prospect ID from URL
    const urlParams = new URLSearchParams(window.location.search);
    const prospectId = urlParams.get('id') || '';
    let prospect: Prospect | undefined;
    let currentPage = 1;
    const pageSize = 25;

    // Expense Window state
    let windowStart: string = '';
    let windowEnd: string = '';

    // Last upload validation results
    let lastUploadValidation: {
      pageCount: number;
      txnCount: number;
      txnPerPage: number;
      warnings: string[];
      statementPeriod: { start?: string; end?: string };
      datesOutsidePeriod: number;
      rawTextSample: string;
    } | null = null;

    // Load prospect from R2
    async function loadProspect() {
      try {
        prospect = await r2GetProspect(prospectId) || undefined;
        if (!prospect) {
          window.location.href = '/';
          return;
        }
        initializePage();
      } catch (e) {
        console.error('Failed to load prospect:', e);
        window.location.href = '/';
      }
    }

    loadProspect();

    // Calculate default 3-month window (ending last day of previous month)
    function getDefault3MonthWindow(): { start: string; end: string } {
      const today = new Date();
      // End of previous month
      const endDate = new Date(today.getFullYear(), today.getMonth(), 0);
      // Start is 3 months before end (first day of that month)
      const startDate = new Date(endDate.getFullYear(), endDate.getMonth() - 2, 1);

      return {
        start: startDate.toISOString().split('T')[0],
        end: endDate.toISOString().split('T')[0]
      };
    }

    // Filter transactions by expense window
    function getFilteredTransactions() {
      if (!prospect) return [];
      if (!windowStart || !windowEnd) return prospect.transactions;

      return prospect.transactions.filter(t => {
        if (!t.date) return false;
        return t.date >= windowStart && t.date <= windowEnd;
      });
    }

    // Validate expense window
    interface LargestGap {
      startDate: string;
      endDate: string;
      days: number;
    }

    function validateWindow(): { duration: { ok: boolean; months: number }; freshness: { ok: boolean; monthsOld: number }; coverage: { days: number; totalDays: number }; largestGap: LargestGap | null } {
      const result = {
        duration: { ok: false, months: 0 },
        freshness: { ok: false, monthsOld: 0 },
        coverage: { days: 0, totalDays: 0 },
        largestGap: null as LargestGap | null
      };

      if (!windowStart || !windowEnd) return result;

      const start = new Date(windowStart);
      const end = new Date(windowEnd);
      const today = new Date();

      // Duration check (should be ~3 months = ~90 days)
      const daysDiff = Math.round((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)) + 1;
      result.duration.months = Math.round(daysDiff / 30 * 10) / 10;
      result.duration.ok = daysDiff >= 84 && daysDiff <= 96; // ~3 months with some tolerance
      result.coverage.totalDays = daysDiff;

      // Freshness check (end date should be within last month)
      const endOfLastMonth = new Date(today.getFullYear(), today.getMonth(), 0);
      const endOfTwoMonthsAgo = new Date(today.getFullYear(), today.getMonth() - 1, 0);
      const monthsOld = (today.getFullYear() - end.getFullYear()) * 12 + (today.getMonth() - end.getMonth());
      result.freshness.monthsOld = monthsOld;
      result.freshness.ok = end >= endOfTwoMonthsAgo; // Can end up to end of previous month

      // Coverage and gaps - check which days have transactions
      if (prospect) {
        const daysWithTxns = new Set<string>();
        for (const txn of prospect.transactions) {
          if (txn.date && txn.date >= windowStart && txn.date <= windowEnd) {
            daysWithTxns.add(txn.date);
          }
        }
        result.coverage.days = daysWithTxns.size;

        // Find largest gap (sequences of 5+ weekdays with no transactions)
        let gapStart: Date | null = null;
        let gapDays = 0;
        let largestGapDays = 0;
        let largestGapStart: Date | null = null;
        let largestGapEnd: Date | null = null;
        const currentDate = new Date(start);

        while (currentDate <= end) {
          const dateStr = currentDate.toISOString().split('T')[0];
          const dayOfWeek = currentDate.getDay();
          const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;

          if (!daysWithTxns.has(dateStr) && !isWeekend) {
            if (!gapStart) gapStart = new Date(currentDate);
            gapDays++;
          } else {
            if (gapDays >= 5 && gapStart && gapDays > largestGapDays) {
              largestGapDays = gapDays;
              largestGapStart = new Date(gapStart);
              largestGapEnd = new Date(currentDate);
              largestGapEnd.setDate(largestGapEnd.getDate() - 1);
            }
            gapStart = null;
            gapDays = 0;
          }
          currentDate.setDate(currentDate.getDate() + 1);
        }

        // Check final gap
        if (gapDays >= 5 && gapStart && gapDays > largestGapDays) {
          largestGapDays = gapDays;
          largestGapStart = new Date(gapStart);
          largestGapEnd = new Date(end);
        }

        if (largestGapStart && largestGapEnd) {
          result.largestGap = {
            startDate: largestGapStart.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short' }),
            endDate: largestGapEnd.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short' }),
            days: largestGapDays
          };
        }
      }

      return result;
    }

    // Render validation panel
    function renderValidation() {
      const validation = validateWindow();
      currentValidation = validation; // Store for modal access

      const durationEl = document.getElementById('val-duration')!;
      const freshnessEl = document.getElementById('val-freshness')!;
      const coverageEl = document.getElementById('val-coverage')!;
      const gapsEl = document.getElementById('val-gaps')!;

      // Duration
      const durationIcon = validation.duration.ok
        ? '<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>'
        : '<svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>';
      durationEl.innerHTML = `${durationIcon} <span class="${validation.duration.ok ? 'text-slate-600' : 'text-amber-600'}">${validation.duration.months} months</span>`;

      // Freshness
      let freshnessText = '';
      let freshnessIcon = '';
      if (validation.freshness.monthsOld <= 0) {
        freshnessText = 'Current';
        freshnessIcon = '<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
      } else if (validation.freshness.ok) {
        freshnessText = `${validation.freshness.monthsOld}mo old`;
        freshnessIcon = '<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
      } else {
        freshnessText = `${validation.freshness.monthsOld}mo old - TOO OLD`;
        freshnessIcon = '<svg class="w-4 h-4 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
      }
      freshnessEl.innerHTML = `${freshnessIcon} <span class="${validation.freshness.ok ? 'text-slate-600' : 'text-rose-600'}">${freshnessText}</span>`;

      // Coverage
      const coveragePct = validation.coverage.totalDays > 0 ? Math.round(validation.coverage.days / validation.coverage.totalDays * 100) : 0;
      coverageEl.innerHTML = `<span class="text-slate-600">${validation.coverage.days}/${validation.coverage.totalDays} days (${coveragePct}%)</span>`;

      // Largest gap - show warning triangle if there's a gap
      if (validation.largestGap) {
        gapsEl.innerHTML = `
          <button onclick="showGapModal()" class="flex items-center gap-1 text-amber-600 hover:text-amber-700 transition-colors" title="Click for details">
            <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <span>Gap: ${validation.largestGap.startDate} - ${validation.largestGap.endDate}</span>
          </button>
        `;
      } else {
        gapsEl.innerHTML = '';
      }
    }

    // Store current validation for modal
    let currentValidation: ReturnType<typeof validateWindow> | null = null;

    // Show extraction validation warnings
    function showValidationWarnings(validation: NonNullable<typeof lastUploadValidation>) {
      const modal = document.getElementById('validation-modal');
      const statsEl = document.getElementById('validation-stats');
      const warningsEl = document.getElementById('validation-warnings');
      const rawTextEl = document.getElementById('validation-raw-text');

      if (!modal || !statsEl || !warningsEl || !rawTextEl) return;

      // Stats
      statsEl.innerHTML = `
        <div class="bg-slate-100 rounded-lg p-3 text-center">
          <p class="text-2xl font-bold text-slate-800">${validation.txnCount}</p>
          <p class="text-xs text-slate-500">Transactions</p>
        </div>
        <div class="bg-slate-100 rounded-lg p-3 text-center">
          <p class="text-2xl font-bold text-slate-800">${validation.pageCount}</p>
          <p class="text-xs text-slate-500">Pages</p>
        </div>
        <div class="bg-${validation.txnPerPage < 3 ? 'amber' : 'slate'}-100 rounded-lg p-3 text-center">
          <p class="text-2xl font-bold text-${validation.txnPerPage < 3 ? 'amber-600' : 'slate-800'}">${validation.txnPerPage.toFixed(1)}</p>
          <p class="text-xs text-slate-500">Per Page</p>
        </div>
      `;

      // Warnings
      warningsEl.innerHTML = validation.warnings.map(w => `
        <div class="flex items-start gap-2 p-3 bg-amber-50 border border-amber-200 rounded-lg">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm text-amber-800">${w}</p>
        </div>
      `).join('');

      // Raw text for debugging
      rawTextEl.textContent = validation.rawTextSample;

      modal.classList.remove('hidden');
    }

    // Show gap modal
    (window as any).showGapModal = () => {
      if (!currentValidation?.largestGap) return;
      const gap = currentValidation.largestGap;
      const modal = document.getElementById('gap-modal');
      const content = document.getElementById('gap-modal-content');
      if (modal && content) {
        content.innerHTML = `
          <p class="text-slate-700 mb-3">The largest gap in transaction data within your expense window:</p>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-amber-700">${gap.days} days</p>
            <p class="text-amber-600 mt-1">${gap.startDate} → ${gap.endDate}</p>
          </div>
          <p class="text-sm text-slate-500 mt-4">No transactions found during this period. Consider obtaining additional statements to fill this gap.</p>
        `;
        modal.classList.remove('hidden');
      }
    };

    // Initialize page function - called after prospect is loaded from R2
    function initializePage() {
      if (!prospect) return;

      // Expense Window selectors
      const windowStartInput = document.getElementById('window-start') as HTMLInputElement;
      const windowEndInput = document.getElementById('window-end') as HTMLInputElement;

      windowStartInput?.addEventListener('change', () => {
      windowStart = windowStartInput.value;
      currentPage = 1;
      renderAnalysis();
    });

    windowEndInput?.addEventListener('change', () => {
      windowEnd = windowEndInput.value;
      currentPage = 1;
      renderAnalysis();
    });

    // Tab switching (Input mode)
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active', 'border-emerald-500', 'text-emerald-600');
          b.classList.add('border-transparent', 'text-slate-500');
        });
        btn.classList.add('active', 'border-emerald-500', 'text-emerald-600');
        btn.classList.remove('border-transparent', 'text-slate-500');

        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      });
    });

    // Output mode tab switching
    document.querySelectorAll('.output-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-output-tab');
