    // Income Calculator
    const incomePayeInput = document.getElementById('income-paye') as HTMLInputElement;
    const incomeBonusInput = document.getElementById('income-bonus') as HTMLInputElement;
    const incomeExpensesInput = document.getElementById('income-expenses') as HTMLInputElement;
    const incomeTestRateInput = document.getElementById('income-test-rate') as HTMLInputElement;
    const incomeDepositPctInput = document.getElementById('income-deposit-pct') as HTMLInputElement;

    function calculateBorrowingCapacity() {
      const monthlyPaye = parseFloat(incomePayeInput?.value || '0') || 0;
      const monthlyBonus = parseFloat(incomeBonusInput?.value || '0') || 0;
      const monthlyExpenses = parseFloat(incomeExpensesInput?.value || '0') || 0;
      const testRate = parseFloat(incomeTestRateInput?.value || '7') || 7;
      const depositPct = parseFloat(incomeDepositPctInput?.value || '20') || 20;

      // Calculate annual figures
      const annualIncome = (monthlyPaye + monthlyBonus) * 12;
      const annualExpenses = monthlyExpenses * 12;
      const annualUmi = annualIncome - annualExpenses;
      const monthlyUmi = annualUmi / 12;

      // Calculate borrowing capacity
      // Max Mortgage = Annual UMI / (Test Rate / 100)
      const maxMortgage = testRate > 0 ? annualUmi / (testRate / 100) : 0;

      // Max Property = Max Mortgage / (1 - Deposit%)
      const depositDecimal = depositPct / 100;
      const maxProperty = depositDecimal < 1 ? maxMortgage / (1 - depositDecimal) : 0;
      const depositAmount = maxProperty - maxMortgage;

      // Update display
      const formatCurrency = (n: number) => new Intl.NumberFormat('en-NZ', {
        style: 'currency',
        currency: 'NZD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(n);

      const annualIncomeEl = document.getElementById('calc-annual-income');
      const annualExpensesEl = document.getElementById('calc-annual-expenses');
      const annualUmiEl = document.getElementById('calc-annual-umi');
      const monthlyUmiEl = document.getElementById('calc-monthly-umi');
      const maxMortgageEl = document.getElementById('calc-max-mortgage');
      const depositAmountEl = document.getElementById('calc-deposit-amount');
      const depositPctDisplayEl = document.getElementById('calc-deposit-pct-display');
      const maxPropertyEl = document.getElementById('calc-max-property');

      if (annualIncomeEl) annualIncomeEl.textContent = formatCurrency(annualIncome);
      if (annualExpensesEl) annualExpensesEl.textContent = formatCurrency(annualExpenses);
      if (annualUmiEl) {
        annualUmiEl.textContent = formatCurrency(annualUmi);
        annualUmiEl.className = `text-xl font-bold ${annualUmi >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      }
      if (monthlyUmiEl) {
        monthlyUmiEl.textContent = formatCurrency(monthlyUmi);
        monthlyUmiEl.className = `text-xl font-bold ${monthlyUmi >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      }
      if (maxMortgageEl) maxMortgageEl.textContent = formatCurrency(Math.max(0, maxMortgage));
      if (depositAmountEl) depositAmountEl.textContent = formatCurrency(Math.max(0, depositAmount));
      if (depositPctDisplayEl) depositPctDisplayEl.textContent = `${depositPct}% of property value`;
      if (maxPropertyEl) maxPropertyEl.textContent = formatCurrency(Math.max(0, maxProperty));
    }

    // Attach event listeners to all income calculator inputs
    [incomePayeInput, incomeBonusInput, incomeExpensesInput, incomeTestRateInput, incomeDepositPctInput].forEach(input => {
      input?.addEventListener('input', calculateBorrowingCapacity);
    });

    // Initial calculation
    calculateBorrowingCapacity();

    // Associated accounts toggle
    let associatedExpanded = false;
    document.getElementById('toggle-associated')?.addEventListener('click', () => {
      associatedExpanded = !associatedExpanded;
      const hiddenSection = document.getElementById('associated-accounts-hidden');
      const toggleText = document.getElementById('toggle-associated-text');
      const toggleIcon = document.getElementById('toggle-associated-icon');

      if (associatedExpanded) {
        hiddenSection?.classList.remove('hidden');
