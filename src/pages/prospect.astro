    // Render average expense (Output mode)
    function renderAverageExpense() {
      if (!prospect) return;

      const analysis = analyzeProspect(prospect);
      const grid = document.getElementById('average-expense-grid');
      const suggestionList = document.getElementById('expense-suggestion-list');

      if (!grid) return;

      // Get spending categories sorted by monthly average
      const categories = analysis.spendingCategories
        .filter(c => c.monthlyAverage > 0)
        .sort((a, b) => b.monthlyAverage - a.monthlyAverage);

      grid.innerHTML = categories.map(cat => {
        const statusIcon = cat.benchmarkStatus === 'above' ?
          '<svg class="w-4 h-4 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" /></svg>' :
          cat.benchmarkStatus === 'below' ?
          '<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>' :
          '';
        const amountClass = cat.benchmarkStatus === 'above' ? 'text-rose-600' :
                           cat.benchmarkStatus === 'below' ? 'text-emerald-600' : 'text-slate-600';

        return `
          <div class="bg-slate-50 rounded-lg p-4 border border-slate-100">
            <div class="flex items-center justify-between mb-2">
              <span class="font-medium text-slate-700">${cat.category}</span>
              ${statusIcon}
            </div>
            <p class="text-2xl font-bold ${amountClass}">${formatCurrency(cat.monthlyAverage)}</p>
            <p class="text-xs text-slate-500 mt-1">per month average</p>
          </div>
        `;
      }).join('');

      // Generate suggestions based on above-benchmark categories
      const suggestions: string[] = [];
      const aboveBenchmark = categories.filter(c => c.benchmarkStatus === 'above');

      for (const cat of aboveBenchmark.slice(0, 4)) {
        if (cat.category === 'Entertainment & Streaming') {
          suggestions.push(`Consider reviewing subscription services - ${cat.category} spending of ${formatCurrency(cat.monthlyAverage)}/month is above average.`);
        } else if (cat.category === 'Dining & Takeaways') {
          suggestions.push(`Reducing dining out frequency could save significantly - current spend is ${formatCurrency(cat.monthlyAverage)}/month.`);
        } else if (cat.category === 'Shopping & Retail') {
          suggestions.push(`Shopping expenses at ${formatCurrency(cat.monthlyAverage)}/month are above benchmark - consider budgeting for discretionary purchases.`);
        } else {
          suggestions.push(`${cat.category} spending of ${formatCurrency(cat.monthlyAverage)}/month is above benchmark.`);
        }
      }

      if (suggestions.length === 0) {
        suggestions.push('Spending is within or below benchmark across all categories - no major concerns identified.');
      }

      if (suggestionList) {
        suggestionList.innerHTML = suggestions.map(s => `<li class="flex items-start gap-2"><span class="text-amber-500 mt-1">•</span> ${s}</li>`).join('');
      }
