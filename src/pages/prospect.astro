    async function renderPdfPage() {
      if (!currentPdfDoc) return;

      const loading = document.getElementById('pdf-loading')!;
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;
      const container = document.getElementById('pdf-container')!;

      loading.classList.remove('hidden');

      try {
        const page = await currentPdfDoc.getPage(currentPdfPage);
        const viewport = page.getViewport({ scale: currentZoom });

        canvas.width = viewport.width;
        canvas.height = viewport.height;

        const ctx = canvas.getContext('2d')!;
        await page.render({ canvasContext: ctx, viewport }).promise;

        // Get text content for highlighting
        const textContent = await page.getTextContent();
        currentTextItems = textContent.items;

        loading.classList.add('hidden');
        canvas.style.display = 'block';

        // Scroll to the transaction
        scrollToTransaction(viewport);

      } catch (error) {
        console.error('Error rendering PDF page:', error);
        loading.classList.add('hidden');
      }
    }

    function scrollToTransaction(viewport: any) {
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;
      const container = document.getElementById('pdf-container')!;

      if (!currentSearchText || currentTextItems.length === 0) {
        return;
      }

      // Search for the text in the page
      const searchLower = currentSearchText.toLowerCase();

      // Build full page text and find match position
      let pageText = '';
      const itemPositions: { start: number; end: number; item: any }[] = [];

      for (const item of currentTextItems) {
        const start = pageText.length;
        pageText += item.str;
        itemPositions.push({ start, end: pageText.length, item });
      }

      const matchPos = pageText.toLowerCase().indexOf(searchLower);
      if (matchPos === -1) {
        return;
      }

      // Find which items contain the match
      const matchingItems: any[] = [];
      for (const pos of itemPositions) {
        if (pos.end > matchPos && pos.start < matchPos + searchLower.length) {
          matchingItems.push(pos.item);
        }
      }

      if (matchingItems.length === 0) {
        return;
      }

      // Calculate vertical position from matching items
      let minY = Infinity, maxY = -Infinity;

      for (const item of matchingItems) {
        const tx = item.transform;
        // Transform coordinates (PDF uses bottom-left origin)
        const y = viewport.height - tx[5];
        const height = tx[0] || 12;

        minY = Math.min(minY, y - height * currentZoom);
        maxY = Math.max(maxY, y);
      }

      // Scroll to center the transaction in view
      const scrollTop = canvas.offsetTop + minY - container.clientHeight / 2 + (maxY - minY) / 2;
      container.scrollTo({ top: Math.max(0, scrollTop), behavior: 'smooth' });
    }

