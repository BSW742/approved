    // =============================================================================
    // Budget Tab Logic
    // =============================================================================

    // Default category-to-expense-type mapping
    const DEFAULT_EXPENSE_TYPES: Record<string, 'committed' | 'regular' | 'discretionary'> = {
      // Committed (Orange) - fixed obligations
      'Utilities': 'committed',
      'Rates': 'committed',
      'Insurance': 'committed',
      'Debt repayments': 'committed',
      'Accommodation costs': 'committed',
      'Child support': 'committed',

      // Regular (Blue) - recurring subscriptions
      'Childcare & education': 'regular',
      'Medical costs': 'regular',
      'Tithing': 'regular',

      // Discretionary (White) - variable/lifestyle
      'ATM withdrawals': 'discretionary',
      'Clothing, shoes & personal care': 'discretionary',
      'Donations': 'discretionary',
      'Entertainment': 'discretionary',
      'Financial services': 'discretionary',
      'Food': 'discretionary',
      'Government and professional services': 'discretionary',
      'Household': 'discretionary',
      'Transport': 'discretionary',
      'Uncategorised': 'discretionary',
    };

    type ExpenseType = 'committed' | 'regular' | 'discretionary';

    interface BudgetItem {
      id: string;
      description: string;
      category: string;
      transactionIds: string[];
      transactionCount: number;
      totalSpent: number;
      actualMonthly: number;
      proposedMonthly: number;
      expenseType: ExpenseType;
      isCustom?: boolean;
      note?: string;
    }

    interface BudgetConfig {
      items: BudgetItem[];
      categoryDefaults: Record<string, ExpenseType>;
      notes: string;
      updatedAt: string;
    }

    // Initialize budget from transaction data if not exists
    function initializeBudget(): BudgetConfig {
      if (!prospect) return { items: [], categoryDefaults: { ...DEFAULT_EXPENSE_TYPES }, notes: '', updatedAt: new Date().toISOString() };

      // If budget exists, return it
      if (prospect.budget) {
        return prospect.budget;
      }

      // Create initial budget - aggregate transactions by description
      const filteredTxns = getFilteredTransactions();
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);

      // Group by description (case-insensitive)
      const descriptionMap = new Map<string, {
        description: string;
        category: string;
        total: number;
        count: number;
        txnIds: string[];
      }>();

      for (const txn of filteredTxns) {
        if (txn.amount >= 0 || txn.isTransfer) continue; // Only expenses, no transfers

        const key = txn.description.toLowerCase().trim();
        const existing = descriptionMap.get(key);

        if (existing) {
          existing.total += Math.abs(txn.amount);
          existing.count++;
          existing.txnIds.push(txn.id);
        } else {
          descriptionMap.set(key, {
            description: txn.description, // Keep original case
            category: txn.category || 'Uncategorised',
            total: Math.abs(txn.amount),
            count: 1,
            txnIds: [txn.id]
          });
        }
      }

      // Convert to budget items
      const items: BudgetItem[] = [];

      for (const data of descriptionMap.values()) {
        const monthlyAvg = data.total / windowMonths;

        items.push({
          id: generateId(),
          description: data.description,
          category: data.category,
          transactionIds: data.txnIds,
          transactionCount: data.count,
          totalSpent: Math.round(data.total * 100) / 100,
          actualMonthly: Math.round(monthlyAvg * 100) / 100,
          proposedMonthly: Math.round(monthlyAvg * 100) / 100,
          expenseType: DEFAULT_EXPENSE_TYPES[data.category] || 'discretionary',
          isCustom: false
        });
      }

      // Sort by actualMonthly descending (biggest expenses first)
      items.sort((a, b) => b.actualMonthly - a.actualMonthly);

      const budget: BudgetConfig = {
        items,
        categoryDefaults: { ...DEFAULT_EXPENSE_TYPES },
        notes: '',
        updatedAt: new Date().toISOString()
      };

      // Save to prospect
      prospect.budget = budget;
      r2SaveProspect(prospect);

      return budget;
    }

    // Render budget table
    function renderBudget() {
      if (!prospect) return;

      const budget = initializeBudget();
      const tbody = document.getElementById('budget-items-body');
      const totalActualEl = document.getElementById('budget-total-actual');
      const totalProposedEl = document.getElementById('budget-total-proposed');
      const totalVarianceEl = document.getElementById('budget-total-variance');
      const surplusEl = document.getElementById('budget-surplus');
      const incomeNoteEl = document.getElementById('budget-income-note');
      const notesTextarea = document.getElementById('budget-notes') as HTMLTextAreaElement;

      if (!tbody) return;

      // Calculate income (for summary)
      const filteredTxns = getFilteredTransactions();
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);
      const moneyIn = filteredTxns.filter(t => t.amount > 0 && !t.isTransfer).reduce((sum, t) => sum + t.amount, 0);
      const monthlyIncome = moneyIn / windowMonths;

      // Render rows
      tbody.innerHTML = budget.items.map(item => {
        // Row colors based on expense type
        let rowClasses = 'border-b border-slate-100 hover:bg-slate-50/50';
        let borderClass = 'border-l-4';
        if (item.expenseType === 'committed') {
          rowClasses = 'bg-orange-50/50 border-b border-orange-100 hover:bg-orange-50';
          borderClass += ' border-l-orange-400';
        } else if (item.expenseType === 'regular') {
          rowClasses = 'bg-blue-50/50 border-b border-blue-100 hover:bg-blue-50';
          borderClass += ' border-l-blue-400';
        } else {
          borderClass += ' border-l-slate-200';
        }

        // Flag one-off transactions (count of 1)
        const isOneOff = !item.isCustom && item.transactionCount === 1;
        const hasTransactions = !item.isCustom && item.transactionIds && item.transactionIds.length > 0;

        return `
          <tr class="${rowClasses} ${borderClass}" data-item-id="${item.id}">
            <td class="px-4 py-3 text-sm text-slate-700">
              <div class="flex items-center gap-2">
                ${hasTransactions ? `
                  <button class="budget-expand-btn text-slate-400 hover:text-slate-600 transition-colors" data-item-id="${item.id}" title="Show transactions">
                    <svg class="w-4 h-4 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                ` : '<span class="w-4"></span>'}
                ${item.isCustom ? `
                  <span class="text-xs bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded">Custom</span>
                  <input type="text" class="budget-desc-input flex-1 px-2 py-1 border border-slate-200 rounded text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
                    value="${item.description.replace(/"/g, '&quot;')}"
                    data-item-id="${item.id}" />
                ` : `
                  <span>${item.description}</span>
                `}
                ${item.note ? '<span class="text-purple-400" title="' + item.note.replace(/"/g, '&quot;') + '">💬</span>' : ''}
              </div>
            </td>
            <td class="px-4 py-3 text-sm text-slate-500">${item.category}</td>
            <td class="px-4 py-3 text-center text-sm ${isOneOff ? 'text-amber-600 font-medium' : 'text-slate-600'}">
              ${item.isCustom ? '-' : item.transactionCount + 'x'}
              ${isOneOff ? '<span class="ml-1" title="One-off - may not recur">⚠️</span>' : ''}
            </td>
            <td class="px-4 py-3 text-right text-sm text-slate-500">${item.isCustom ? '-' : formatCurrency(item.totalSpent)}</td>
            <td class="px-4 py-3 text-right text-sm text-slate-700">${formatCurrency(item.actualMonthly)}</td>
            <td class="px-4 py-3 text-right">
              <input type="number" step="0.01" min="0"
                class="budget-proposed-input w-24 text-right px-2 py-1 border border-slate-200 rounded text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
                value="${item.proposedMonthly.toFixed(2)}"
                data-item-id="${item.id}" />
            </td>
            <td class="px-4 py-3 text-center">
              <select class="budget-type-select text-xs px-2 py-1 border border-slate-200 rounded focus:ring-2 focus:ring-emerald-500 outline-none" data-item-id="${item.id}">
                <option value="committed" ${item.expenseType === 'committed' ? 'selected' : ''}>Committed</option>
                <option value="regular" ${item.expenseType === 'regular' ? 'selected' : ''}>Regular</option>
                <option value="discretionary" ${item.expenseType === 'discretionary' ? 'selected' : ''}>Discretionary</option>
              </select>
            </td>
            <td class="px-4 py-3 text-center flex items-center justify-center gap-1">
              <button class="budget-note-btn ${item.note ? 'text-purple-500' : 'text-slate-300'} hover:text-purple-600 transition-colors" data-item-id="${item.id}" title="${item.note ? 'Edit note' : 'Add note'}">
                <svg class="w-5 h-5" fill="${item.note ? 'currentColor' : 'none'}" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                </svg>
              </button>
              <button class="budget-delete-btn text-slate-300 hover:text-rose-500 transition-colors" data-item-id="${item.id}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </td>
          </tr>
          <tr class="budget-txn-row hidden" data-parent-id="${item.id}">
            <td colspan="8" class="px-4 py-0">
              <div class="budget-txn-content bg-slate-50 rounded-lg my-2 p-3 text-sm"></div>
            </td>
          </tr>
        `;
      }).join('');

      // Calculate totals
      const totalActual = budget.items.reduce((sum, item) => sum + item.actualMonthly, 0);
      const totalProposed = budget.items.reduce((sum, item) => sum + item.proposedMonthly, 0);
      const totalVariance = totalActual - totalProposed;

      if (totalActualEl) totalActualEl.textContent = formatCurrency(totalActual);
      if (totalProposedEl) totalProposedEl.textContent = formatCurrency(totalProposed);
      if (totalVarianceEl) {
        totalVarianceEl.textContent = (totalVariance > 0 ? '+' : '') + formatCurrency(totalVariance);
        totalVarianceEl.className = `text-right px-4 py-3 font-semibold ${totalVariance > 0 ? 'text-emerald-600' : totalVariance < 0 ? 'text-rose-600' : 'text-slate-500'}`;
      }

      // Summary
      const surplus = monthlyIncome - totalProposed;
      if (surplusEl) {
        surplusEl.textContent = (surplus >= 0 ? '+' : '') + formatCurrency(surplus) + '/month';
        surplusEl.className = `text-xl font-bold ${surplus >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      }
      if (incomeNoteEl) {
        incomeNoteEl.textContent = `Based on ${formatCurrency(monthlyIncome)}/month income from expense window`;
      }

      // Notes
      if (notesTextarea && budget.notes) {
        notesTextarea.value = budget.notes;
      }

      // Attach event listeners
      attachBudgetEventListeners();
    }

    // Attach event listeners to budget elements
    function attachBudgetEventListeners() {
      // Proposed amount inputs
      document.querySelectorAll('.budget-proposed-input').forEach(input => {
        input.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          const itemId = target.dataset.itemId;
          const value = parseFloat(target.value) || 0;
          updateBudgetProposed(itemId!, value);
        });
      });

      // Type selects
      document.querySelectorAll('.budget-type-select').forEach(select => {
        select.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          const itemId = target.dataset.itemId;
          const value = target.value as ExpenseType;
          updateBudgetType(itemId!, value);
        });
      });

      // Delete buttons
      document.querySelectorAll('.budget-delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = (e.currentTarget as HTMLElement);
          const itemId = target.dataset.itemId;
          deleteBudgetItem(itemId!);
        });
      });

      // Note buttons
      document.querySelectorAll('.budget-note-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = (e.currentTarget as HTMLElement);
          const itemId = target.dataset.itemId;
          openBudgetNoteModal(itemId!);
        });
      });

      // Expand buttons (show underlying transactions)
      document.querySelectorAll('.budget-expand-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = (e.currentTarget as HTMLElement);
          const itemId = target.dataset.itemId;
          toggleBudgetTransactions(itemId!, target);
        });
      });

      // Description inputs (for custom items)
      document.querySelectorAll('.budget-desc-input').forEach(input => {
        input.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          const itemId = target.dataset.itemId;
          updateBudgetDescription(itemId!, target.value);
        });
      });

      // Notes textarea
      const notesTextarea = document.getElementById('budget-notes') as HTMLTextAreaElement;
      notesTextarea?.addEventListener('change', () => {
        if (!prospect || !prospect.budget) return;
        prospect.budget.notes = notesTextarea.value;
        prospect.budget.updatedAt = new Date().toISOString();
        r2SaveProspect(prospect);
      });
    }

    // Budget note modal state
    let currentBudgetNoteItemId: string | null = null;

    function openBudgetNoteModal(itemId: string) {
      if (!prospect || !prospect.budget) return;

      const item = prospect.budget.items.find(i => i.id === itemId);
      if (!item) return;

      currentBudgetNoteItemId = itemId;

      const modal = document.getElementById('budget-note-modal');
      const descEl = document.getElementById('budget-note-item-desc');
      const inputEl = document.getElementById('budget-note-input') as HTMLTextAreaElement;

      if (descEl) descEl.textContent = `${item.description} - ${item.category}`;
      if (inputEl) inputEl.value = item.note || '';

      modal?.classList.remove('hidden');
      inputEl?.focus();
    }

    function closeBudgetNoteModal() {
      document.getElementById('budget-note-modal')?.classList.add('hidden');
      currentBudgetNoteItemId = null;
    }

    function saveBudgetNote() {
      if (!prospect || !prospect.budget || !currentBudgetNoteItemId) return;

      const inputEl = document.getElementById('budget-note-input') as HTMLTextAreaElement;
      const note = inputEl?.value.trim() || '';

      const item = prospect.budget.items.find(i => i.id === currentBudgetNoteItemId);
      if (item) {
        item.note = note || undefined;
        prospect.budget.updatedAt = new Date().toISOString();
        r2SaveProspect(prospect);
        renderBudget();
      }

      closeBudgetNoteModal();
    }

    function clearBudgetNote() {
      const inputEl = document.getElementById('budget-note-input') as HTMLTextAreaElement;
      if (inputEl) inputEl.value = '';
    }

    // Budget note modal event listeners
    document.getElementById('close-budget-note-modal')?.addEventListener('click', closeBudgetNoteModal);
    document.getElementById('save-budget-note')?.addEventListener('click', saveBudgetNote);
    document.getElementById('clear-budget-note')?.addEventListener('click', clearBudgetNote);
    document.getElementById('budget-note-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeBudgetNoteModal();
    });

    // Update proposed amount
    function updateBudgetProposed(itemId: string, value: number) {
      if (!prospect || !prospect.budget) return;

      const item = prospect.budget.items.find(i => i.id === itemId);
      if (item) {
        item.proposedMonthly = Math.round(value * 100) / 100;
        prospect.budget.updatedAt = new Date().toISOString();
        r2SaveProspect(prospect);
        renderBudget();
      }
    }

    // Update expense type
    function updateBudgetType(itemId: string, type: ExpenseType) {
      if (!prospect || !prospect.budget) return;

      const item = prospect.budget.items.find(i => i.id === itemId);
      if (item) {
        item.expenseType = type;
        prospect.budget.updatedAt = new Date().toISOString();
        r2SaveProspect(prospect);
        renderBudget();
      }
    }

    // Delete budget item
    function deleteBudgetItem(itemId: string) {
      if (!prospect || !prospect.budget) return;

      prospect.budget.items = prospect.budget.items.filter(i => i.id !== itemId);
      prospect.budget.updatedAt = new Date().toISOString();
      r2SaveProspect(prospect);
      renderBudget();
    }

    // Add custom budget item
    function addCustomBudgetItem() {
      if (!prospect) return;

      if (!prospect.budget) {
        initializeBudget();
      }

      const newItem: BudgetItem = {
        id: generateId(),
        description: 'New expense',
        category: 'Uncategorised',
        transactionIds: [],
        transactionCount: 0,
        totalSpent: 0,
        actualMonthly: 0,
        proposedMonthly: 0,
        expenseType: 'discretionary',
        isCustom: true
      };

      prospect.budget!.items.push(newItem);
      prospect.budget!.updatedAt = new Date().toISOString();
      r2SaveProspect(prospect);
      renderBudget();

      // Focus the new row's description input
      setTimeout(() => {
        const row = document.querySelector(`tr[data-item-id="${newItem.id}"]`);
        const descInput = row?.querySelector('.budget-desc-input') as HTMLInputElement;
        if (descInput) {
          descInput.focus();
          descInput.select();
        }
      }, 100);
    }

    // Add item button handler
    document.getElementById('add-budget-item')?.addEventListener('click', addCustomBudgetItem);

    // Toggle transaction details expansion
    function toggleBudgetTransactions(itemId: string, btn: HTMLElement) {
      if (!prospect || !prospect.budget) return;

      const item = prospect.budget.items.find(i => i.id === itemId);
      if (!item || !item.transactionIds || item.transactionIds.length === 0) return;

      const txnRow = document.querySelector(`tr.budget-txn-row[data-parent-id="${itemId}"]`);
      const contentEl = txnRow?.querySelector('.budget-txn-content');
      const svgIcon = btn.querySelector('svg');

      if (!txnRow || !contentEl) return;

      const isExpanded = !txnRow.classList.contains('hidden');

      if (isExpanded) {
        // Collapse
        txnRow.classList.add('hidden');
        svgIcon?.classList.remove('rotate-90');
      } else {
        // Expand - populate with transaction details
        const txns = prospect.transactions.filter(t => item.transactionIds.includes(t.id));
        txns.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

        contentEl.innerHTML = `
          <div class="text-xs text-slate-500 mb-2">
            ${txns.length} transaction${txns.length !== 1 ? 's' : ''} totaling ${formatCurrency(item.totalSpent)} over expense window
          </div>
          <table class="w-full text-xs">
            <thead>
              <tr class="text-slate-500 border-b border-slate-200">
                <th class="text-left py-1 font-medium">Date</th>
                <th class="text-left py-1 font-medium">Description</th>
                <th class="text-right py-1 font-medium">Amount</th>
              </tr>
            </thead>
            <tbody>
              ${txns.map(txn => `
                <tr class="border-b border-slate-100">
                  <td class="py-1.5 text-slate-600">${formatDate(txn.date)}</td>
                  <td class="py-1.5 text-slate-700">${txn.description}</td>
                  <td class="py-1.5 text-right text-slate-700">${formatCurrency(Math.abs(txn.amount))}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        `;

        txnRow.classList.remove('hidden');
        svgIcon?.classList.add('rotate-90');
      }
    }

    // Update description for custom items
    function updateBudgetDescription(itemId: string, description: string) {
      if (!prospect || !prospect.budget) return;

      const item = prospect.budget.items.find(i => i.id === itemId);
      if (item && item.isCustom) {
        item.description = description.trim() || 'New expense';
        prospect.budget.updatedAt = new Date().toISOString();
        r2SaveProspect(prospect);
      }
    }

    // Regenerate budget from transactions (clears existing budget)
    function regenerateBudget() {
      if (!prospect) return;
      if (!confirm('This will replace your current budget with fresh data from transactions. Continue?')) return;

      // Clear existing budget
      delete prospect.budget;

      // Re-initialize and render
      initializeBudget();
      renderBudget();
    }

    document.getElementById('regenerate-budget')?.addEventListener('click', regenerateBudget);

    // PDF Viewer state
    let currentPdfDoc: any = null;
    let currentPdfPage = 1;
    let currentZoom = 1.5;
    let currentTextItems: any[] = [];
    let currentSearchText = '';

    // Show PDF detail modal
    (window as any).showPdfDetail = async (txnId: string) => {
      if (!prospect) return;

      const txn = prospect.transactions.find(t => t.id === txnId);
      if (!txn || !txn.documentId) {
        alert('Document not available for this transaction');
        return;
      }

      const doc = prospect.documents.find(d => d.id === txn.documentId);
      const modal = document.getElementById('pdf-modal')!;
      const loading = document.getElementById('pdf-loading')!;
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;

      // Show modal with loading state
      modal.classList.remove('hidden');
      loading.classList.remove('hidden');
      canvas.style.display = 'none';

      // Set header info (same format as search results)
      document.getElementById('pdf-modal-title')!.textContent = doc?.filename || 'Document';
      document.getElementById('pdf-modal-subtitle')!.textContent = `Page ${txn.pageNumber || 1} • ${txn.description}`;

      try {
        // Get PDF from IndexedDB (local cache) or fall back to R2
        let pdfData = await getPDF(txn.documentId);
        if (!pdfData) {
          // Try to fetch from R2
          pdfData = await r2GetPDF(prospectId, txn.documentId);
          if (pdfData) {
            // Cache locally for next time
            await savePDF(txn.documentId, pdfData, []);
          }
        }
        if (!pdfData) {
          alert('PDF document not found. It may have been uploaded before this feature was added.');
          modal.classList.add('hidden');
          return;
        }

        // Load PDF
        currentPdfDoc = await pdfjsLib.getDocument({ data: pdfData }).promise;
        currentPdfPage = txn.pageNumber || 1;
        currentSearchText = txn.rawDescription?.substring(0, 30) || txn.textMatch || '';
        currentZoom = 1.5;

        document.getElementById('pdf-page-info')!.textContent = `Page ${currentPdfPage} of ${currentPdfDoc.numPages}`;
        document.getElementById('pdf-zoom-level')!.textContent = `${Math.round(currentZoom * 100)}%`;

        await renderPdfPage();

      } catch (error) {
        console.error('Error loading PDF:', error);
        alert('Error loading PDF document');
        modal.classList.add('hidden');
      }
    };

    async function renderPdfPage() {
      if (!currentPdfDoc) return;

      const loading = document.getElementById('pdf-loading')!;
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;
      const container = document.getElementById('pdf-container')!;

      loading.classList.remove('hidden');

      try {
        const page = await currentPdfDoc.getPage(currentPdfPage);
        const viewport = page.getViewport({ scale: currentZoom });

        canvas.width = viewport.width;
        canvas.height = viewport.height;

        const ctx = canvas.getContext('2d')!;
        await page.render({ canvasContext: ctx, viewport }).promise;

        // Get text content for highlighting
        const textContent = await page.getTextContent();
        currentTextItems = textContent.items;

        loading.classList.add('hidden');
        canvas.style.display = 'block';

        // Scroll to the transaction
        scrollToTransaction(viewport);

      } catch (error) {
        console.error('Error rendering PDF page:', error);
        loading.classList.add('hidden');
      }
    }

    function scrollToTransaction(viewport: any) {
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;
      const container = document.getElementById('pdf-container')!;

      if (!currentSearchText || currentTextItems.length === 0) {
        return;
      }

      // Search for the text in the page
      const searchLower = currentSearchText.toLowerCase();

      // Build full page text and find match position
      let pageText = '';
      const itemPositions: { start: number; end: number; item: any }[] = [];

      for (const item of currentTextItems) {
        const start = pageText.length;
        pageText += item.str;
        itemPositions.push({ start, end: pageText.length, item });
      }

      const matchPos = pageText.toLowerCase().indexOf(searchLower);
      if (matchPos === -1) {
        return;
      }

      // Find which items contain the match
      const matchingItems: any[] = [];
      for (const pos of itemPositions) {
        if (pos.end > matchPos && pos.start < matchPos + searchLower.length) {
          matchingItems.push(pos.item);
        }
      }

      if (matchingItems.length === 0) {
        return;
      }

      // Calculate vertical position from matching items
      let minY = Infinity, maxY = -Infinity;

      for (const item of matchingItems) {
        const tx = item.transform;
        // Transform coordinates (PDF uses bottom-left origin)
        const y = viewport.height - tx[5];
        const height = tx[0] || 12;

        minY = Math.min(minY, y - height * currentZoom);
        maxY = Math.max(maxY, y);
      }

      // Scroll to center the transaction in view
      const scrollTop = canvas.offsetTop + minY - container.clientHeight / 2 + (maxY - minY) / 2;
      container.scrollTo({ top: Math.max(0, scrollTop), behavior: 'smooth' });
    }

    // PDF modal controls
    document.getElementById('close-pdf-modal')?.addEventListener('click', () => {
      document.getElementById('pdf-modal')?.classList.add('hidden');
      currentPdfDoc = null;
    });

    document.getElementById('pdf-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        document.getElementById('pdf-modal')?.classList.add('hidden');
        currentPdfDoc = null;
      }
    });

    document.getElementById('pdf-zoom-in')?.addEventListener('click', async () => {
      currentZoom = Math.min(currentZoom + 0.25, 3);
      document.getElementById('pdf-zoom-level')!.textContent = `${Math.round(currentZoom * 100)}%`;
      await renderPdfPage();
    });

    document.getElementById('pdf-zoom-out')?.addEventListener('click', async () => {
      currentZoom = Math.max(currentZoom - 0.25, 0.5);
      document.getElementById('pdf-zoom-level')!.textContent = `${Math.round(currentZoom * 100)}%`;
      await renderPdfPage();
    });

    // Keyboard shortcuts for PDF modal
    document.addEventListener('keydown', (e) => {
      const modal = document.getElementById('pdf-modal');
      if (modal?.classList.contains('hidden')) return;

      if (e.key === 'Escape') {
        modal?.classList.add('hidden');
        currentPdfDoc = null;
      }
    });

    // Document search functionality
    let searchTimeout: any = null;
    const docSearchInput = document.getElementById('doc-search') as HTMLInputElement;
    const searchResults = document.getElementById('search-results')!;
    const noSearchResults = document.getElementById('no-search-results')!;
    const searchEmpty = document.getElementById('search-empty')!;

    docSearchInput?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      const query = docSearchInput.value.trim();

      if (!query) {
        searchResults.innerHTML = '';
        noSearchResults.classList.add('hidden');
        searchEmpty.classList.remove('hidden');
        return;
      }

      searchEmpty.classList.add('hidden');
      searchTimeout = setTimeout(() => performDocSearch(query), 300);
    });

    async function performDocSearch(query: string) {
      if (!prospect) return;

      const results: { docId: string; docName: string; pageNumber: number; snippet: string; matchText: string }[] = [];
      const queryLower = query.toLowerCase();

      for (const doc of prospect.documents) {
        try {
          const pdfData = await getPDFWithText(doc.id);
          if (!pdfData || !pdfData.pageTexts) continue;

          for (const pt of pdfData.pageTexts) {
            const textLower = pt.text.toLowerCase();
            let pos = 0;
            while ((pos = textLower.indexOf(queryLower, pos)) !== -1) {
              // Get snippet around match
              const start = Math.max(0, pos - 40);
              const end = Math.min(pt.text.length, pos + query.length + 40);
              let snippet = pt.text.substring(start, end);
              if (start > 0) snippet = '...' + snippet;
              if (end < pt.text.length) snippet = snippet + '...';

              results.push({
                docId: doc.id,
                docName: doc.filename,
                pageNumber: pt.pageNumber,
                snippet,
                matchText: query
              });

              pos += query.length;

              // Limit results per document
              if (results.filter(r => r.docId === doc.id).length >= 10) break;
            }
          }
        } catch (e) {
          console.error('Error searching doc:', doc.id, e);
        }
      }

      // Render results
      if (results.length === 0) {
        searchResults.innerHTML = '';
        noSearchResults.classList.remove('hidden');
        return;
      }

      noSearchResults.classList.add('hidden');
      searchResults.innerHTML = results.slice(0, 50).map((r, i) => `
        <button onclick="openSearchResult('${r.docId}', ${r.pageNumber}, '${r.matchText.replace(/'/g, "\\'")}')"
                class="w-full text-left p-4 bg-slate-50 hover:bg-emerald-50 rounded-lg border border-slate-200 hover:border-emerald-300 transition-colors group">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-sm text-slate-900 font-medium truncate">${r.docName}</p>
              <p class="text-xs text-slate-500 mt-0.5">Page ${r.pageNumber}</p>
              <p class="text-sm text-slate-600 mt-2 line-clamp-2">${highlightMatch(r.snippet, r.matchText)}</p>
            </div>
            <svg class="w-5 h-5 text-slate-400 group-hover:text-emerald-500 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </button>
      `).join('');
    }

    function highlightMatch(text: string, match: string): string {
      const regex = new RegExp(`(${match.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark class="bg-emerald-200 text-emerald-900 px-0.5 rounded">$1</mark>');
    }

    // Open search result in PDF modal
    (window as any).openSearchResult = async (docId: string, pageNumber: number, matchText: string) => {
      const doc = prospect?.documents.find(d => d.id === docId);
      const modal = document.getElementById('pdf-modal')!;
      const loading = document.getElementById('pdf-loading')!;
      const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;

      modal.classList.remove('hidden');
      loading.classList.remove('hidden');
      canvas.style.display = 'none';

      document.getElementById('pdf-modal-title')!.textContent = doc?.filename || 'Document';
      document.getElementById('pdf-modal-subtitle')!.textContent = `Page ${pageNumber} • Search result`;

      try {
        let pdfData = await getPDF(docId);
        if (!pdfData) {
          // Try to fetch from R2
          pdfData = await r2GetPDF(prospectId, docId);
          if (pdfData) {
            // Cache locally for next time
            await savePDF(docId, pdfData, []);
          }
        }
        if (!pdfData) {
          alert('PDF not found');
          modal.classList.add('hidden');
          return;
        }

        currentPdfDoc = await pdfjsLib.getDocument({ data: pdfData }).promise;
        currentPdfPage = pageNumber;
        currentSearchText = matchText;
        currentZoom = 1.5;

        document.getElementById('pdf-page-info')!.textContent = `Page ${pageNumber} of ${currentPdfDoc.numPages}`;
        document.getElementById('pdf-zoom-level')!.textContent = `${Math.round(currentZoom * 100)}%`;

        await renderPdfPage();

      } catch (error) {
        console.error('Error opening search result:', error);
        alert('Error loading document');
        modal.classList.add('hidden');
      }
    };

    // Clear all data button
    document.getElementById('clear-all-btn')?.addEventListener('click', async () => {
      if (!prospect) return;

      const confirmed = confirm('This will delete all transactions and documents for this prospect. You will need to re-upload your PDFs. Continue?');
      if (!confirmed) return;

      try {
        // Clear IndexedDB (local cache)
        await clearAllPDFs();

        // Clear prospect data
        prospect.transactions = [];
        prospect.documents = [];
        prospect.accounts = [];
        await r2SaveProspect(prospect);

        // Re-render
        renderAnalysis();
        alert('All data cleared. Please re-upload your PDFs.');
      } catch (error) {
        console.error('Error clearing data:', error);
        alert('Error clearing data. Please try refreshing the page.');
      }
    });

    // Category detail modal
    (window as any).showCategoryDetail = (category: string) => {
      if (!prospect) return;

      const filteredTxns = getFilteredTransactions();

      // Build category data from filtered transactions
      let categoryTxns: typeof filteredTxns;
      if (category === 'Account Transfers') {
        categoryTxns = filteredTxns.filter(t => t.isTransfer);
      } else {
        categoryTxns = filteredTxns.filter(t => !t.isTransfer && t.category === category);
        // If expenses only mode, filter to debits
        if (expensesOnly) {
          categoryTxns = categoryTxns.filter(t => t.amount < 0);
        }
      }

      if (categoryTxns.length === 0) return;

      const total = Math.abs(categoryTxns.reduce((sum, t) => sum + t.amount, 0));

      // Calculate months for average
      const dates = categoryTxns.map(t => t.date).filter(Boolean);
      const months = new Set(dates.map(d => d.substring(0, 7)));
      const monthCount = Math.max(1, months.size);
      const monthlyAverage = total / monthCount;

      document.getElementById('modal-title')!.textContent = category;

      const benchmark = BENCHMARKS[category];
      const benchmarkStatus = benchmark ? (monthlyAverage > benchmark.high ? 'above' : monthlyAverage < benchmark.low ? 'below' : 'normal') : 'normal';

      document.getElementById('modal-summary')!.innerHTML = `
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Total</p>
          <p class="text-xl font-bold text-slate-900">${formatCurrency(total)}</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Monthly Avg</p>
          <p class="text-xl font-bold text-slate-900">${formatCurrency(monthlyAverage)}</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Benchmark</p>
          <p class="text-xl font-bold ${benchmarkStatus === 'above' ? 'text-rose-600' : benchmarkStatus === 'below' ? 'text-emerald-600' : 'text-slate-900'}">
            ${benchmark ? `$${benchmark.average}/mo` : 'N/A'}
          </p>
        </div>
      `;

      document.getElementById('modal-transactions')!.innerHTML = categoryTxns.map(txn => `
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-600">${formatDate(txn.date)}</td>
          <td class="py-2 text-slate-900">${txn.description}</td>
          <td class="py-2 text-right font-medium ${category === 'Account Transfers' ? 'text-indigo-600' : 'text-rose-600'}">${formatCurrency(Math.abs(txn.amount))}</td>
        </tr>
      `).join('');

      document.getElementById('category-modal')?.classList.remove('hidden');
    };

    document.getElementById('close-modal')?.addEventListener('click', () => {
      document.getElementById('category-modal')?.classList.add('hidden');
    });

    document.getElementById('category-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        document.getElementById('category-modal')?.classList.add('hidden');
      }
    });

    // Search and filter handlers
    document.getElementById('txn-search')?.addEventListener('input', () => {
      currentPage = 1;
      renderTransactions();
    });

    document.getElementById('txn-category-filter')?.addEventListener('change', () => {
      currentPage = 1;
      renderTransactions();
    });

    (window as any).changePage = (page: number) => {
      currentPage = page;
      renderTransactions();
    };

      // Load benchmark settings and render
      loadBenchmarksFromSettings().then(() => {
        renderAnalysis();
      });
    }
  </script>
</Layout>
