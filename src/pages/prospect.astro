---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prospect Analysis">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div id="header" class="mb-8">
      <a href="/" class="text-slate-500 hover:text-emerald-600 text-sm flex items-center gap-1 mb-4 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Prospects
      </a>
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 id="prospect-name" class="text-3xl font-bold text-slate-900">Loading...</h1>
          <p id="prospect-period" class="text-slate-500 mt-1"></p>
        </div>
        <div class="flex gap-3">
          <label class="bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-5 py-2.5 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-sm hover:shadow cursor-pointer flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            Upload Statement
            <input type="file" id="pdf-upload" accept=".pdf" multiple class="hidden" />
          </label>
        </div>
      </div>
    </div>

    <!-- Upload Progress -->
    <div id="upload-progress" class="hidden mb-6 bg-emerald-50 border border-emerald-200 rounded-xl p-4">
      <div class="flex items-center gap-3">
        <div class="animate-spin w-5 h-5 border-2 border-emerald-500 border-t-transparent rounded-full"></div>
        <span class="text-emerald-700 font-medium">Processing PDF...</span>
      </div>
    </div>

    <!-- No Data State -->
    <div id="no-data" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-700 mb-2">No statements uploaded</h2>
        <p class="text-slate-500 mb-6">Upload bank statement PDFs to analyze spending patterns</p>
        <label class="inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-6 py-3 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-md hover:shadow-lg cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          Upload PDF Statement
          <input type="file" accept=".pdf" multiple class="hidden pdf-upload-trigger" />
        </label>
      </div>
    </div>

    <!-- Analysis Content -->
    <div id="analysis-content" class="hidden space-y-6">
      <!-- Summary Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <p class="text-sm text-slate-500 mb-1">Money In</p>
          <p id="total-in" class="text-2xl font-bold text-emerald-600">$0.00</p>
          <p id="monthly-in" class="text-xs text-slate-400 mt-1"></p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <p class="text-sm text-slate-500 mb-1">Money Out</p>
          <p id="total-out" class="text-2xl font-bold text-rose-600">$0.00</p>
          <p id="monthly-out" class="text-xs text-slate-400 mt-1"></p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <p class="text-sm text-slate-500 mb-1">Net Position</p>
          <p id="net-position" class="text-2xl font-bold">$0.00</p>
          <p id="net-monthly" class="text-xs text-slate-400 mt-1"></p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <p class="text-sm text-slate-500 mb-1">Documents</p>
          <p id="doc-count" class="text-2xl font-bold text-slate-700">0</p>
          <p id="txn-count" class="text-xs text-slate-400 mt-1"></p>
        </div>
      </div>

      <!-- Anomalies Alert -->
      <div id="anomalies-alert" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-amber-800">Items Requiring Attention</h3>
            <div id="anomalies-list" class="mt-2 space-y-2 text-sm text-amber-700"></div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="border-b border-slate-200 overflow-x-auto">
          <nav class="flex -mb-px min-w-max">
            <button data-tab="overview" class="tab-btn active px-6 py-4 text-sm font-medium border-b-2 border-emerald-500 text-emerald-600 whitespace-nowrap">Overview</button>
            <button data-tab="categories" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Spending Categories</button>
            <button data-tab="transactions" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Transactions</button>
            <button data-tab="documents" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Documents</button>
          </nav>
        </div>

        <!-- Overview Tab -->
        <div id="tab-overview" class="tab-content p-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Money In -->
            <div>
              <h3 class="font-semibold text-slate-700 mb-4">Money In</h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Salary</span>
                  <div class="text-right">
                    <span id="salary-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="salary-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Government Support</span>
                  <div class="text-right">
                    <span id="govt-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="govt-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Other Money In</span>
                  <div class="text-right">
                    <span id="other-in-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="other-in-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Key Indicators -->
            <div>
              <h3 class="font-semibold text-slate-700 mb-4">Key Indicators</h3>
              <div class="space-y-3" id="key-indicators">
                <!-- Populated by JS -->
              </div>
            </div>
          </div>
        </div>

        <!-- Categories Tab -->
        <div id="tab-categories" class="tab-content hidden p-6">
          <div id="categories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Transactions Tab -->
        <div id="tab-transactions" class="tab-content hidden p-6">
          <div class="mb-4 flex flex-col sm:flex-row gap-4">
            <input type="text" id="txn-search" placeholder="Search transactions..." class="flex-1 px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            <select id="txn-category-filter" class="px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none">
              <option value="">All Categories</option>
            </select>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[600px]">
              <thead>
                <tr class="text-left text-sm text-slate-500 border-b border-slate-200">
                  <th class="pb-3 font-medium">Date</th>
                  <th class="pb-3 font-medium">Description</th>
                  <th class="pb-3 font-medium">Category</th>
                  <th class="pb-3 font-medium text-right">Amount</th>
                </tr>
              </thead>
              <tbody id="transactions-table" class="text-sm">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
          <div id="txn-pagination" class="mt-4 flex justify-center gap-2"></div>
        </div>

        <!-- Documents Tab -->
        <div id="tab-documents" class="tab-content hidden p-6">
          <div id="documents-list" class="space-y-3">
            <!-- Populated by JS -->
          </div>
        </div>
      </div>
    </div>

    <!-- Category Detail Modal -->
    <div id="category-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-xl max-w-3xl w-full max-h-[80vh] overflow-hidden">
        <div class="p-6 border-b border-slate-200 flex items-center justify-between">
          <h3 id="modal-title" class="text-xl font-semibold text-slate-900"></h3>
          <button id="close-modal" class="text-slate-400 hover:text-slate-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="p-6 overflow-y-auto max-h-[60vh]">
          <div id="modal-summary" class="mb-6 grid grid-cols-3 gap-4 text-center"></div>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-slate-500 border-b border-slate-200">
                <th class="pb-3 font-medium">Date</th>
                <th class="pb-3 font-medium">Description</th>
                <th class="pb-3 font-medium text-right">Amount</th>
              </tr>
            </thead>
            <tbody id="modal-transactions"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    import { getProspect, saveProspect, mergeTransactions, generateId } from '../lib/store';
    import type { Prospect } from '../lib/store';
    import { analyzeProspect, formatCurrency, formatDate, formatPeriod } from '../lib/analysis';
    import { detectBank, parseANZStatement, parseWestpacStatement, parseGenericStatement } from '../lib/pdfParser';
    import { CATEGORY_COLORS, BENCHMARKS } from '../lib/categorize';

    // Set up PDF.js worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';

    // Get prospect ID from URL
    const urlParams = new URLSearchParams(window.location.search);
    const prospectId = urlParams.get('id') || '';
    let prospect: Prospect | undefined = getProspect(prospectId);
    let currentPage = 1;
    const pageSize = 25;

    if (!prospect) {
      window.location.href = '/';
    }

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active', 'border-emerald-500', 'text-emerald-600');
          b.classList.add('border-transparent', 'text-slate-500');
        });
        btn.classList.add('active', 'border-emerald-500', 'text-emerald-600');
        btn.classList.remove('border-transparent', 'text-slate-500');

        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      });
    });

    // PDF Upload handling
    document.querySelectorAll('#pdf-upload, .pdf-upload-trigger').forEach(input => {
      input.addEventListener('change', async (e) => {
        const files = (e.target as HTMLInputElement).files;
        if (!files || !prospect) return;

        const progressEl = document.getElementById('upload-progress');
        progressEl?.classList.remove('hidden');

        for (const file of Array.from(files)) {
          await processPDF(file);
        }

        progressEl?.classList.add('hidden');
        (e.target as HTMLInputElement).value = '';
        renderAnalysis();
      });
    });

    async function processPDF(file: File) {
      if (!prospect) return;

      try {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;

        let fullText = '';
        for (let i = 1; i <= pdf.numPages; i++) {
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          const pageText = textContent.items.map((item: any) => item.str).join(' ');
          fullText += pageText + '\n';
        }

        const bank = detectBank(fullText);
        let result;

        switch (bank) {
          case 'ANZ':
            result = parseANZStatement(fullText, file.name);
            break;
          case 'Westpac':
            result = parseWestpacStatement(fullText, file.name);
            break;
          default:
            result = parseGenericStatement(fullText, file.name, bank);
        }

        // Merge transactions
        prospect.transactions = mergeTransactions(prospect.transactions, result.transactions);

        // Add accounts (avoid duplicates)
        for (const account of result.accounts) {
          if (!prospect.accounts.find(a => a.number === account.number)) {
            prospect.accounts.push(account);
          }
        }

        // Add document
        result.document.pageCount = pdf.numPages;
        prospect.documents.push(result.document);

        saveProspect(prospect);

      } catch (error) {
        console.error('Error processing PDF:', error);
        alert(`Error processing ${file.name}. Please ensure it's a valid bank statement PDF.`);
      }
    }

    function renderAnalysis() {
      if (!prospect) return;

      // Update header
      document.getElementById('prospect-name')!.textContent = prospect.name;

      if (prospect.transactions.length === 0) {
        document.getElementById('no-data')?.classList.remove('hidden');
        document.getElementById('analysis-content')?.classList.add('hidden');
        document.getElementById('prospect-period')!.textContent = 'No statements uploaded';
        return;
      }

      document.getElementById('no-data')?.classList.add('hidden');
      document.getElementById('analysis-content')?.classList.remove('hidden');

      const analysis = analyzeProspect(prospect);

      // Update period
      document.getElementById('prospect-period')!.textContent = formatPeriod(analysis.period.start, analysis.period.end);

      // Summary cards
      document.getElementById('total-in')!.textContent = formatCurrency(analysis.moneyIn);
      document.getElementById('monthly-in')!.textContent = `${formatCurrency(analysis.moneyIn / analysis.period.months)}/month`;
      document.getElementById('total-out')!.textContent = formatCurrency(analysis.moneyOut);
      document.getElementById('monthly-out')!.textContent = `${formatCurrency(analysis.moneyOut / analysis.period.months)}/month`;

      const net = analysis.moneyIn - analysis.moneyOut;
      const netEl = document.getElementById('net-position')!;
      netEl.textContent = formatCurrency(net, true);
      netEl.className = `text-2xl font-bold ${net >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      document.getElementById('net-monthly')!.textContent = `${formatCurrency(net / analysis.period.months, true)}/month`;

      document.getElementById('doc-count')!.textContent = prospect.documents.length.toString();
      document.getElementById('txn-count')!.textContent = `${prospect.transactions.length} transactions`;

      // Money In section
      document.getElementById('salary-total')!.textContent = formatCurrency(analysis.moneyInSummary.salary.total);
      document.getElementById('salary-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.salary.monthly)}/mo)`;
      document.getElementById('govt-total')!.textContent = formatCurrency(analysis.moneyInSummary.governmentSupport.total);
      document.getElementById('govt-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.governmentSupport.monthly)}/mo)`;
      document.getElementById('other-in-total')!.textContent = formatCurrency(analysis.moneyInSummary.otherMoneyIn.total);
      document.getElementById('other-in-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.otherMoneyIn.monthly)}/mo)`;

      // Key Indicators
      const indicators = [
        { name: 'ATM Withdrawals', data: analysis.keyIndicators.atmWithdrawals },
        { name: 'Debt Repayment', data: analysis.keyIndicators.debtRepayment },
        { name: 'Dishonours', data: analysis.keyIndicators.dishonours, isWarning: true },
        { name: 'Fees', data: analysis.keyIndicators.fees },
        { name: 'Gambling', data: analysis.keyIndicators.gambling, isWarning: true },
      ];

      document.getElementById('key-indicators')!.innerHTML = indicators.map(ind => `
        <div class="flex justify-between items-center py-2 border-b border-slate-100 ${ind.isWarning && ind.data.count > 0 ? 'bg-rose-50 -mx-2 px-2 rounded' : ''}">
          <span class="text-slate-600 ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700 font-medium' : ''}">${ind.name}</span>
          <div class="text-right">
            <span class="font-medium ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700' : 'text-slate-700'}">${ind.data.count}</span>
            <span class="text-xs text-slate-400 ml-2">${formatCurrency(ind.data.total)}</span>
          </div>
        </div>
      `).join('');

      // Anomalies
      const highAnomalies = analysis.anomalies.filter(a => a.severity === 'high' || a.severity === 'medium');
      if (highAnomalies.length > 0) {
        document.getElementById('anomalies-alert')?.classList.remove('hidden');
        document.getElementById('anomalies-list')!.innerHTML = highAnomalies.map(a => `
          <div class="flex items-start gap-2">
            <span class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${a.severity === 'high' ? 'bg-rose-500' : 'bg-amber-500'}"></span>
            <div>
              <p>${a.reason}</p>
              ${a.suggestion ? `<p class="text-amber-600 text-xs mt-0.5">${a.suggestion}</p>` : ''}
            </div>
          </div>
        `).join('');
      } else {
        document.getElementById('anomalies-alert')?.classList.add('hidden');
      }

      // Categories
      renderCategories(analysis);

      // Transactions
      renderTransactions();

      // Documents
      renderDocuments();
    }

    function renderCategories(analysis: ReturnType<typeof analyzeProspect>) {
      const grid = document.getElementById('categories-grid')!;
      const categories = analysis.spendingCategories.filter(c => c.transactionCount > 0);

      grid.innerHTML = categories.map(cat => {
        const color = CATEGORY_COLORS[cat.category] || '#94a3b8';
        const benchmark = BENCHMARKS[cat.category];
        let benchmarkIndicator = '';

        if (benchmark) {
          if (cat.benchmarkStatus === 'above') {
            benchmarkIndicator = `<span class="text-xs text-rose-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
              Above avg
            </span>`;
          } else if (cat.benchmarkStatus === 'below') {
            benchmarkIndicator = `<span class="text-xs text-emerald-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Below avg
            </span>`;
          }
        }

        return `
          <button onclick="showCategoryDetail('${cat.category}')" class="bg-slate-50 hover:bg-slate-100 rounded-lg p-4 text-left transition-colors group">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full" style="background-color: ${color}"></div>
                <span class="font-medium text-slate-700 group-hover:text-emerald-600 transition-colors">${cat.category}</span>
              </div>
              <span class="text-xs text-slate-400">${cat.transactionCount} txns</span>
            </div>
            <div class="flex items-end justify-between">
              <div>
                <p class="text-lg font-semibold text-slate-900">${formatCurrency(cat.total)}</p>
                <p class="text-xs text-slate-500">${formatCurrency(cat.monthlyAverage)}/month</p>
              </div>
              ${benchmarkIndicator}
            </div>
          </button>
        `;
      }).join('');
    }

    function renderTransactions() {
      if (!prospect) return;

      const search = (document.getElementById('txn-search') as HTMLInputElement).value.toLowerCase();
      const categoryFilter = (document.getElementById('txn-category-filter') as HTMLSelectElement).value;

      let filtered = prospect.transactions;

      if (search) {
        filtered = filtered.filter(t => t.description.toLowerCase().includes(search) || t.rawDescription.toLowerCase().includes(search));
      }

      if (categoryFilter) {
        filtered = filtered.filter(t => t.category === categoryFilter);
      }

      const totalPages = Math.ceil(filtered.length / pageSize);
      const start = (currentPage - 1) * pageSize;
      const paginated = filtered.slice(start, start + pageSize);

      const tbody = document.getElementById('transactions-table')!;
      tbody.innerHTML = paginated.map(txn => `
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="py-3 text-slate-600 whitespace-nowrap">${formatDate(txn.date)}</td>
          <td class="py-3">
            <p class="text-slate-900">${txn.description}</p>
            ${txn.isAnomalous ? `<p class="text-xs text-amber-600">${txn.anomalyReason}</p>` : ''}
          </td>
          <td class="py-3">
            <span class="px-2 py-1 rounded text-xs font-medium whitespace-nowrap" style="background-color: ${CATEGORY_COLORS[txn.category]}20; color: ${CATEGORY_COLORS[txn.category]}">${txn.category}</span>
          </td>
          <td class="py-3 text-right font-medium whitespace-nowrap ${txn.amount >= 0 ? 'text-emerald-600' : 'text-rose-600'}">${formatCurrency(txn.amount, true)}</td>
        </tr>
      `).join('');

      // Populate category filter
      const categories = [...new Set(prospect.transactions.map(t => t.category))].sort();
      const filter = document.getElementById('txn-category-filter') as HTMLSelectElement;
      const currentValue = filter.value;
      filter.innerHTML = '<option value="">All Categories</option>' + categories.map(c => `<option value="${c}" ${c === currentValue ? 'selected' : ''}>${c}</option>`).join('');

      // Pagination
      const pagination = document.getElementById('txn-pagination')!;
      if (totalPages > 1) {
        pagination.innerHTML = `
          <button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="px-3 py-1 rounded border ${currentPage === 1 ? 'text-slate-300 border-slate-200' : 'text-slate-600 border-slate-300 hover:bg-slate-50'}">Prev</button>
          <span class="px-3 py-1 text-slate-600">Page ${currentPage} of ${totalPages}</span>
          <button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="px-3 py-1 rounded border ${currentPage === totalPages ? 'text-slate-300 border-slate-200' : 'text-slate-600 border-slate-300 hover:bg-slate-50'}">Next</button>
        `;
      } else {
        pagination.innerHTML = '';
      }
    }

    function renderDocuments() {
      if (!prospect) return;

      const list = document.getElementById('documents-list')!;

      if (prospect.documents.length === 0) {
        list.innerHTML = '<p class="text-slate-500 text-center py-8">No documents uploaded yet</p>';
        return;
      }

      list.innerHTML = prospect.documents.map(doc => `
        <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-rose-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="min-w-0">
              <p class="font-medium text-slate-700 truncate">${doc.filename}</p>
              <p class="text-xs text-slate-500">${doc.bank} &bull; ${doc.pageCount || '?'} pages &bull; Uploaded ${formatDate(doc.uploadedAt)}</p>
            </div>
          </div>
        </div>
      `).join('');
    }

    // Category detail modal
    (window as any).showCategoryDetail = (category: string) => {
      if (!prospect) return;

      const analysis = analyzeProspect(prospect);
      const cat = analysis.spendingCategories.find(c => c.category === category);
      if (!cat) return;

      document.getElementById('modal-title')!.textContent = category;

      const benchmark = BENCHMARKS[category];
      document.getElementById('modal-summary')!.innerHTML = `
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Total</p>
          <p class="text-xl font-bold text-slate-900">${formatCurrency(cat.total)}</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Monthly Avg</p>
          <p class="text-xl font-bold text-slate-900">${formatCurrency(cat.monthlyAverage)}</p>
        </div>
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs text-slate-500">Benchmark</p>
          <p class="text-xl font-bold ${cat.benchmarkStatus === 'above' ? 'text-rose-600' : cat.benchmarkStatus === 'below' ? 'text-emerald-600' : 'text-slate-900'}">
            ${benchmark ? `$${benchmark.average}/mo` : 'N/A'}
          </p>
        </div>
      `;

      document.getElementById('modal-transactions')!.innerHTML = cat.transactions.map(txn => `
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-600">${formatDate(txn.date)}</td>
          <td class="py-2 text-slate-900">${txn.description}</td>
          <td class="py-2 text-right font-medium text-rose-600">${formatCurrency(txn.amount)}</td>
        </tr>
      `).join('');

      document.getElementById('category-modal')?.classList.remove('hidden');
    };

    document.getElementById('close-modal')?.addEventListener('click', () => {
      document.getElementById('category-modal')?.classList.add('hidden');
    });

    document.getElementById('category-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        document.getElementById('category-modal')?.classList.add('hidden');
      }
    });

    // Search and filter handlers
    document.getElementById('txn-search')?.addEventListener('input', () => {
      currentPage = 1;
      renderTransactions();
    });

    document.getElementById('txn-category-filter')?.addEventListener('change', () => {
      currentPage = 1;
      renderTransactions();
    });

    (window as any).changePage = (page: number) => {
      currentPage = page;
      renderTransactions();
    };

    // Initial render
    renderAnalysis();
  </script>
</Layout>
