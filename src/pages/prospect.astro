---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prospect Analysis">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div id="header" class="mb-8">
      <a href="/" class="text-slate-500 hover:text-emerald-600 text-sm flex items-center gap-1 mb-4 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Prospects
      </a>
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 id="prospect-name" class="text-3xl font-bold text-slate-900">Loading...</h1>
          <p id="prospect-period" class="text-slate-500 mt-1"></p>
        </div>
        <div class="flex items-center gap-4">
          <label class="flex items-center gap-2 text-sm text-slate-600 cursor-pointer select-none">
            <input type="checkbox" id="expenses-only" class="w-4 h-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" checked />
            <span>Expenses only</span>
          </label>
          <label class="bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-5 py-2.5 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-sm hover:shadow cursor-pointer flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            Upload Statement
            <input type="file" id="pdf-upload" accept=".pdf" multiple class="hidden" />
          </label>
        </div>
      </div>
    </div>

    <!-- Upload Progress -->
    <div id="upload-progress" class="hidden mb-6 bg-emerald-50 border border-emerald-200 rounded-xl p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="animate-spin w-5 h-5 border-2 border-emerald-500 border-t-transparent rounded-full"></div>
          <div>
            <span id="upload-status" class="text-emerald-700 font-medium">Processing...</span>
            <p id="upload-detail" class="text-emerald-600 text-sm"></p>
          </div>
        </div>
        <span id="upload-count" class="text-emerald-600 text-sm font-medium"></span>
      </div>
      <div id="upload-progress-bar" class="mt-3 h-2 bg-emerald-100 rounded-full overflow-hidden">
        <div id="upload-progress-fill" class="h-full bg-emerald-500 transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- No Data State -->
    <div id="no-data" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-700 mb-2">No statements uploaded</h2>
        <p class="text-slate-500 mb-6">Upload bank statement PDFs to analyze spending patterns</p>
        <label class="inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-6 py-3 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-md hover:shadow-lg cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          Upload PDF Statement
          <input type="file" accept=".pdf" multiple class="hidden pdf-upload-trigger" />
        </label>
      </div>
    </div>

    <!-- Analysis Content -->
    <div id="analysis-content" class="hidden space-y-6">
      <!-- Summary Bar: Month selector, Money Out, Documents -->
      <div class="bg-white rounded-xl border border-slate-200 p-4">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <!-- Month Selector -->
          <div class="flex items-center gap-3">
            <button id="prev-month" class="p-2 rounded-lg border border-slate-200 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <select id="month-selector" class="px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none text-sm font-medium min-w-[160px]">
              <option value="all">All Months</option>
            </select>
            <button id="next-month" class="p-2 rounded-lg border border-slate-200 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Money Out -->
          <div class="flex items-center gap-3">
            <div class="text-right">
              <p class="text-xs text-slate-500 uppercase tracking-wide">Total Expenses</p>
              <p id="total-out" class="text-2xl font-bold text-rose-600">$0.00</p>
            </div>
            <p id="monthly-out" class="text-xs text-slate-400 hidden sm:block"></p>
          </div>

          <!-- Documents -->
          <div class="flex items-center gap-2 text-slate-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span id="doc-count" class="font-semibold text-slate-700">0</span>
            <span class="text-sm">docs</span>
            <span class="text-slate-300 mx-1">|</span>
            <span id="txn-count" class="text-sm text-slate-500"></span>
          </div>
        </div>
      </div>

      <!-- Hidden income cards (kept for data but not displayed by default) -->
      <div id="summary-cards" class="hidden">
        <div id="card-money-in" class="income-section">
          <p id="total-in" class="hidden">$0.00</p>
          <p id="monthly-in" class="hidden"></p>
        </div>
        <div id="card-net" class="income-section">
          <p id="net-position" class="hidden">$0.00</p>
          <p id="net-monthly" class="hidden"></p>
        </div>
      </div>

      <!-- Mode Toggle -->
      <div class="flex justify-center mb-6">
        <div class="inline-flex bg-slate-100 rounded-full p-1">
          <button id="mode-input" class="mode-btn px-6 py-2 rounded-full text-sm font-medium transition-all bg-white text-emerald-600 shadow-sm">
            Input
          </button>
          <button id="mode-output" class="mode-btn px-6 py-2 rounded-full text-sm font-medium transition-all text-slate-500 hover:text-slate-700">
            Output
          </button>
        </div>
      </div>

      <!-- Input Mode Tabs -->
      <div id="input-mode" class="bg-white rounded-xl border border-slate-200">
        <div class="border-b border-slate-200 overflow-x-auto">
          <nav class="flex -mb-px min-w-max">
            <button data-tab="transactions" class="tab-btn active px-6 py-4 text-sm font-medium border-b-2 border-emerald-500 text-emerald-600 whitespace-nowrap">Transactions</button>
            <button data-tab="categories" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Categories</button>
            <button data-tab="attention" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Attention</button>
            <button data-tab="overview" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Overview</button>
            <button data-tab="search" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              Search Docs
            </button>
            <button data-tab="accounts" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Associated Accounts</button>
            <button data-tab="transfers" class="tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Account Transfers</button>
          </nav>
        </div>

        <!-- Overview Tab -->
        <div id="tab-overview" class="tab-content hidden p-6">
          <div id="overview-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <!-- Money In -->
            <div id="money-in-section" class="income-section">
              <h3 class="font-semibold text-slate-700 mb-4">Money In</h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Salary</span>
                  <div class="text-right">
                    <span id="salary-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="salary-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Government Support</span>
                  <div class="text-right">
                    <span id="govt-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="govt-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-100">
                  <span class="text-slate-600">Other Money In</span>
                  <div class="text-right">
                    <span id="other-in-total" class="font-medium text-slate-700">$0.00</span>
                    <span id="other-in-monthly" class="text-xs text-slate-400 ml-2"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Key Indicators -->
            <div>
              <h3 class="font-semibold text-slate-700 mb-4">Key Indicators</h3>
              <div class="space-y-3" id="key-indicators">
                <!-- Populated by JS -->
              </div>
            </div>
          </div>

          <!-- Documents Section -->
          <div class="border-t border-slate-200 pt-6">
            <div class="flex justify-between items-center mb-4">
              <h3 class="font-semibold text-slate-700">Documents</h3>
              <button id="clear-all-btn" class="text-xs px-3 py-1.5 rounded border border-rose-200 text-rose-600 hover:bg-rose-50 transition-colors">
                Clear All & Reset
              </button>
            </div>
            <div id="documents-list" class="space-y-3">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <!-- Categories Tab -->
        <div id="tab-categories" class="tab-content hidden p-6">
          <div id="categories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Attention Tab -->
        <div id="tab-attention" class="tab-content hidden p-6">
          <div class="mb-4">
            <p class="text-sm text-slate-500">Items that may require review. Transactions marked as account transfers are excluded.</p>
          </div>
          <div id="attention-list" class="space-y-3">
            <!-- Populated by JS -->
          </div>
          <div id="no-attention" class="hidden text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>No items requiring attention</p>
          </div>
        </div>

        <!-- Transactions Tab -->
        <div id="tab-transactions" class="tab-content p-6">
          <div class="mb-4 flex flex-col sm:flex-row gap-4">
            <input type="text" id="txn-search" placeholder="Search transactions..." class="flex-1 px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            <select id="txn-category-filter" class="px-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none">
              <option value="">All Categories</option>
            </select>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[600px]">
              <thead>
                <tr class="text-left text-sm text-slate-500 border-b border-slate-200">
                  <th class="pb-3 font-medium">Date</th>
                  <th class="pb-3 font-medium">Description</th>
                  <th class="pb-3 font-medium">Category</th>
                  <th class="pb-3 font-medium text-right">Amount</th>
                  <th class="pb-3 font-medium text-center w-12"></th>
                  <th class="pb-3 font-medium text-center w-12"></th>
                  <th class="pb-3 font-medium text-center w-12"></th>
                </tr>
              </thead>
              <tbody id="transactions-table" class="text-sm">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
          <div id="txn-pagination" class="mt-4 flex justify-center gap-2"></div>
        </div>

        <!-- Account Transfers Tab -->
        <div id="tab-transfers" class="tab-content hidden p-6">
          <div class="mb-4">
            <p class="text-sm text-slate-500">Transactions marked as account transfers are excluded from expense calculations.</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[600px]">
              <thead>
                <tr class="text-left text-sm text-slate-500 border-b border-slate-200">
                  <th class="pb-3 font-medium">Date</th>
                  <th class="pb-3 font-medium">Description</th>
                  <th class="pb-3 font-medium text-right">Amount</th>
                  <th class="pb-3 font-medium text-center w-24">Action</th>
                </tr>
              </thead>
              <tbody id="transfers-table" class="text-sm">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
          <div id="no-transfers" class="hidden text-center py-8 text-slate-400">
            No account transfers marked yet. Mark transactions as transfers from the Transactions tab.
          </div>
        </div>

        <!-- Search Tab -->
        <div id="tab-search" class="tab-content hidden p-6">
          <div class="max-w-2xl mx-auto">
            <div class="mb-6">
              <div class="relative">
                <input type="text" id="doc-search" placeholder="Search in all documents..." class="w-full px-4 py-3 pl-12 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none text-lg" />
                <svg class="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <p class="text-sm text-slate-500 mt-2">Search for any text in your uploaded bank statements</p>
            </div>
            <div id="search-results" class="space-y-2">
              <!-- Populated by JS -->
            </div>
            <div id="no-search-results" class="hidden text-center py-12 text-slate-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <p>No results found</p>
            </div>
            <div id="search-empty" class="text-center py-12 text-slate-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p>Type to search your documents</p>
            </div>
          </div>
        </div>

        <!-- Accounts Tab -->
        <div id="tab-accounts" class="tab-content hidden p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-lg font-semibold text-slate-800">Associated Accounts</h3>
              <p class="text-sm text-slate-500">External accounts with money flowing in or out</p>
            </div>
            <button id="toggle-associated" class="hidden text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center gap-1">
              <span id="toggle-associated-text">Show All</span>
              <svg id="toggle-associated-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
          <div id="associated-accounts-list" class="space-y-2">
            <!-- Populated by JS -->
          </div>
          <div id="associated-accounts-hidden" class="hidden space-y-2 mt-2 pt-2 border-t border-slate-200">
            <!-- Hidden accounts (< $1000) populated by JS -->
          </div>
          <div id="no-accounts" class="hidden text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p>No associated accounts detected</p>
          </div>
        </div>

      </div>

      <!-- Output Mode Tabs -->
      <div id="output-mode" class="hidden bg-white rounded-xl border border-slate-200">
        <div class="border-b border-slate-200 overflow-x-auto">
          <nav class="flex -mb-px min-w-max">
            <button data-output-tab="average" class="output-tab-btn active px-6 py-4 text-sm font-medium border-b-2 border-emerald-500 text-emerald-600 whitespace-nowrap">Average Expense</button>
            <button data-output-tab="summary" class="output-tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Application Summary</button>
            <button data-output-tab="log" class="output-tab-btn px-6 py-4 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 whitespace-nowrap">Log</button>
          </nav>
        </div>

        <!-- Average Expense Tab -->
        <div id="output-tab-average" class="output-tab-content p-6">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-slate-800 mb-2">Average Monthly Expenses</h3>
            <p class="text-sm text-slate-500">Based on uploaded statements, here's the average monthly spending breakdown.</p>
          </div>
          <div id="average-expense-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <!-- Populated by JS -->
          </div>
          <div id="expense-suggestions" class="bg-amber-50 border border-amber-200 rounded-lg p-4">
            <h4 class="font-medium text-amber-800 mb-2 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
              Suggestions to Reduce Expenses
            </h4>
            <ul id="expense-suggestion-list" class="space-y-2 text-sm text-amber-700">
              <!-- Populated by JS -->
            </ul>
          </div>
        </div>

        <!-- Application Summary Tab -->
        <div id="output-tab-summary" class="output-tab-content hidden p-6">
          <div class="mb-6 flex items-center justify-between">
            <div>
              <h3 class="text-lg font-semibold text-slate-800 mb-2">Application Summary</h3>
              <p class="text-sm text-slate-500">Narrative summary ready to copy/paste into application forms.</p>
            </div>
            <button id="copy-summary" class="flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              Copy to Clipboard
            </button>
          </div>
          <div id="application-summary-content" class="bg-slate-50 rounded-lg p-6 border border-slate-200 whitespace-pre-wrap font-mono text-sm text-slate-700 max-h-[60vh] overflow-y-auto">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Log Tab -->
        <div id="output-tab-log" class="output-tab-content hidden p-6">
          <div class="mb-4">
            <p class="text-sm text-slate-500">Actions taken to represent data correctly - notes and transfer markings.</p>
          </div>
          <div id="log-list" class="space-y-2">
            <!-- Populated by JS -->
          </div>
          <div id="no-log" class="hidden text-center py-12 text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
