    // Render average expense (Output mode)
    // Pie chart state for hover effects
    let pieChartData: { category: string; amount: number; color: string; percentage: number }[] = [];

    // Local benchmark check for pie chart
    function getBenchmarkStatusLocal(category: string, monthlyAverage: number): 'above' | 'below' | 'normal' {
      const benchmark = BENCHMARKS[category];
      if (!benchmark) return 'normal';
      if (monthlyAverage > benchmark.high) return 'above';
      if (monthlyAverage < benchmark.low) return 'below';
      return 'normal';
    }

    function renderAverageExpense() {
      if (!prospect) return;

      const grid = document.getElementById('average-expense-grid');
      const suggestionList = document.getElementById('expense-suggestion-list');
      const pieChart = document.getElementById('expense-pie-chart');
      const pieLegend = document.getElementById('pie-legend');
      const pieTotal = document.getElementById('pie-total');

      if (!grid || !pieChart) return;

      // Use expense window filtered transactions (same as header avg monthly)
      const filteredTxns = getFilteredTransactions();

      // Calculate months in expense window
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);

      // Build spending categories from filtered transactions (excluding transfers)
      const categoryMap = new Map<string, { total: number; count: number }>();

      for (const txn of filteredTxns) {
        if (txn.amount >= 0 || txn.isTransfer) continue; // Only expenses, no transfers

        const cat = txn.category || 'Uncategorised';
        const existing = categoryMap.get(cat) || { total: 0, count: 0 };
        existing.total += Math.abs(txn.amount);
        existing.count++;
        categoryMap.set(cat, existing);
      }

      // Convert to array with monthly averages
      const categories = Array.from(categoryMap.entries())
        .map(([category, data]) => ({
          category,
          total: data.total,
          count: data.count,
          monthlyAverage: data.total / windowMonths,
          benchmarkStatus: getBenchmarkStatusLocal(category, data.total / windowMonths)
        }))
        .filter(c => c.monthlyAverage > 0)
        .sort((a, b) => b.monthlyAverage - a.monthlyAverage);

      const total = categories.reduce((sum, c) => sum + c.monthlyAverage, 0);

      // Update total display with animation
      if (pieTotal) {
        pieTotal.textContent = formatCurrency(total);
      }

      // Prepare pie chart data
      pieChartData = categories.map(cat => ({
        category: cat.category,
        amount: cat.monthlyAverage,
        color: CATEGORY_COLORS[cat.category] || '#94a3b8',
        percentage: total > 0 ? (cat.monthlyAverage / total) * 100 : 0
      }));

      // Render animated pie chart
      renderPieChart(pieChart, pieChartData);

      // Render legend
      if (pieLegend) {
        pieLegend.innerHTML = pieChartData.slice(0, 8).map((item, index) => `
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer pie-legend-item" data-index="${index}">
            <div class="w-4 h-4 rounded-full flex-shrink-0 shadow-sm" style="background-color: ${item.color}"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-slate-700 truncate">${item.category}</p>
              <p class="text-xs text-slate-500">${formatCurrency(item.amount)}/mo</p>
            </div>
            <span class="text-sm font-semibold text-slate-600">${item.percentage.toFixed(1)}%</span>
          </div>
        `).join('');

        // Add hover effects to legend items
        pieLegend.querySelectorAll('.pie-legend-item').forEach((item, index) => {
          item.addEventListener('mouseenter', () => highlightPieSlice(index));
          item.addEventListener('mouseleave', () => unhighlightPieSlice(index));
        });
      }

      // Render category cards (smaller, more compact)
      grid.innerHTML = categories.map((cat, index) => {
        const color = CATEGORY_COLORS[cat.category] || '#94a3b8';
        const statusIcon = cat.benchmarkStatus === 'above' ?
          '<svg class="w-3.5 h-3.5 text-rose-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>' :
          cat.benchmarkStatus === 'below' ?
          '<svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>' :
          '';
        const bgClass = cat.benchmarkStatus === 'above' ? 'bg-rose-50 border-rose-100' :
                        cat.benchmarkStatus === 'below' ? 'bg-emerald-50 border-emerald-100' : 'bg-slate-50 border-slate-100';
        const amountClass = cat.benchmarkStatus === 'above' ? 'text-rose-600' :
                           cat.benchmarkStatus === 'below' ? 'text-emerald-600' : 'text-slate-700';

        return `
          <div class="rounded-xl p-3 border ${bgClass} hover:shadow-md transition-all duration-200 cursor-pointer pie-card-item"
               data-index="${index}"
               style="animation: fadeSlideIn 0.4s ease-out ${index * 0.05}s both">
            <div class="flex items-center gap-2 mb-1">
              <div class="w-2.5 h-2.5 rounded-full" style="background-color: ${color}"></div>
              <span class="text-xs font-medium text-slate-600 truncate flex-1">${cat.category}</span>
              ${statusIcon}
            </div>
            <p class="text-lg font-bold ${amountClass}">${formatCurrency(cat.monthlyAverage)}</p>
          </div>
        `;
      }).join('');

      // Add hover effects to cards
      grid.querySelectorAll('.pie-card-item').forEach((item, index) => {
        item.addEventListener('mouseenter', () => highlightPieSlice(index));
        item.addEventListener('mouseleave', () => unhighlightPieSlice(index));
      });

      // Generate suggestions based on above-benchmark categories
      const suggestions: string[] = [];
      const aboveBenchmark = categories.filter(c => c.benchmarkStatus === 'above');

      for (const cat of aboveBenchmark.slice(0, 4)) {
        if (cat.category === 'Entertainment & Streaming') {
          suggestions.push(`Consider reviewing subscription services - ${cat.category} spending of ${formatCurrency(cat.monthlyAverage)}/month is above average.`);
        } else if (cat.category === 'Dining & Takeaways') {
          suggestions.push(`Reducing dining out frequency could save significantly - current spend is ${formatCurrency(cat.monthlyAverage)}/month.`);
        } else if (cat.category === 'Shopping & Retail') {
          suggestions.push(`Shopping expenses at ${formatCurrency(cat.monthlyAverage)}/month are above benchmark - consider budgeting for discretionary purchases.`);
        } else {
          suggestions.push(`${cat.category} spending of ${formatCurrency(cat.monthlyAverage)}/month is above benchmark.`);
        }
      }

      if (suggestions.length === 0) {
        suggestions.push('Spending is within or below benchmark across all categories - no major concerns identified.');
      }

      if (suggestionList) {
        suggestionList.innerHTML = suggestions.map(s => `<li class="flex items-start gap-2"><span class="text-amber-500 mt-1">•</span> ${s}</li>`).join('');
      }
    }

    function renderPieChart(svg: Element, data: typeof pieChartData) {
      const cx = 160, cy = 160, radius = 120, innerRadius = 70;
      let currentAngle = 0;

      // Clear existing content
      svg.innerHTML = '';

      // Add drop shadow filter
      const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
      defs.innerHTML = `
        <filter id="pie-shadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="2" stdDeviation="3" flood-opacity="0.15"/>
        </filter>
      `;
      svg.appendChild(defs);

      data.forEach((item, index) => {
        const angle = (item.percentage / 100) * 360;
        const startAngle = currentAngle;
        const endAngle = currentAngle + angle;

        // Create donut slice path
        const path = createDonutSlice(cx, cy, radius, innerRadius, startAngle, endAngle);

        const pathElement = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        pathElement.setAttribute('d', path);
        pathElement.setAttribute('fill', item.color);
        pathElement.setAttribute('class', 'pie-slice');
        pathElement.setAttribute('data-index', index.toString());
        pathElement.setAttribute('filter', 'url(#pie-shadow)');
        pathElement.style.transformOrigin = `${cx}px ${cy}px`;
        pathElement.style.transition = 'transform 0.2s ease-out, opacity 0.2s ease-out';

        // Animate in with staggered delay
        pathElement.style.opacity = '0';
        pathElement.style.transform = 'scale(0.8)';

        setTimeout(() => {
          pathElement.style.opacity = '1';
          pathElement.style.transform = 'scale(1)';
        }, index * 80);

        // Hover effects
        pathElement.addEventListener('mouseenter', () => highlightPieSlice(index));
        pathElement.addEventListener('mouseleave', () => unhighlightPieSlice(index));

        svg.appendChild(pathElement);
        currentAngle = endAngle;
      });
    }

    function createDonutSlice(cx: number, cy: number, outerR: number, innerR: number, startAngle: number, endAngle: number): string {
      // Convert to radians
      const startRad = (startAngle - 90) * Math.PI / 180;
      const endRad = (endAngle - 90) * Math.PI / 180;

      // Calculate points
      const x1 = cx + outerR * Math.cos(startRad);
      const y1 = cy + outerR * Math.sin(startRad);
      const x2 = cx + outerR * Math.cos(endRad);
      const y2 = cy + outerR * Math.sin(endRad);
      const x3 = cx + innerR * Math.cos(endRad);
      const y3 = cy + innerR * Math.sin(endRad);
      const x4 = cx + innerR * Math.cos(startRad);
      const y4 = cy + innerR * Math.sin(startRad);

      const largeArc = endAngle - startAngle > 180 ? 1 : 0;

      return `M ${x1} ${y1} A ${outerR} ${outerR} 0 ${largeArc} 1 ${x2} ${y2} L ${x3} ${y3} A ${innerR} ${innerR} 0 ${largeArc} 0 ${x4} ${y4} Z`;
    }

    function highlightPieSlice(index: number) {
      const slices = document.querySelectorAll('.pie-slice');
      slices.forEach((slice, i) => {
        if (i === index) {
          (slice as HTMLElement).style.transform = 'scale(1.08)';
          (slice as HTMLElement).style.opacity = '1';
        } else {
          (slice as HTMLElement).style.opacity = '0.4';
        }
      });

      // Highlight legend item
      const legendItems = document.querySelectorAll('.pie-legend-item');
      legendItems.forEach((item, i) => {
        if (i === index) {
          (item as HTMLElement).style.backgroundColor = '#f1f5f9';
          (item as HTMLElement).style.transform = 'scale(1.02)';
        }
      });

      // Highlight card
      const cards = document.querySelectorAll('.pie-card-item');
      cards.forEach((card, i) => {
        if (i === index) {
          (card as HTMLElement).style.transform = 'scale(1.05)';
          (card as HTMLElement).style.boxShadow = '0 10px 25px -5px rgba(0,0,0,0.1)';
        } else {
          (card as HTMLElement).style.opacity = '0.5';
        }
      });
    }

    function unhighlightPieSlice(index: number) {
      const slices = document.querySelectorAll('.pie-slice');
      slices.forEach((slice) => {
        (slice as HTMLElement).style.transform = 'scale(1)';
        (slice as HTMLElement).style.opacity = '1';
      });

      const legendItems = document.querySelectorAll('.pie-legend-item');
      legendItems.forEach((item) => {
        (item as HTMLElement).style.backgroundColor = '';
        (item as HTMLElement).style.transform = '';
      });

      const cards = document.querySelectorAll('.pie-card-item');
      cards.forEach((card) => {
        (card as HTMLElement).style.transform = '';
        (card as HTMLElement).style.boxShadow = '';
        (card as HTMLElement).style.opacity = '';
      });
    }

    // Default NZ benchmarks (weekly * 4.33 = monthly)
    const DEFAULT_BENCHMARKS_DATA: Record<string, { groceries: number; utilities: number; entertainment: number; insurance: number }> = {
      '1adult': { groceries: 585, utilities: 238, entertainment: 281, insurance: 130 },
      '2adults': { groceries: 953, utilities: 346, entertainment: 455, insurance: 217 },
      '1adult1child': { groceries: 931, utilities: 325, entertainment: 390, insurance: 217 },
      '1adult2children': { groceries: 1234, utilities: 411, entertainment: 455, insurance: 260 },
      '2adults1child': { groceries: 1234, utilities: 411, entertainment: 520, insurance: 260 },
      '2adults2children': { groceries: 1559, utilities: 476, entertainment: 585, insurance: 325 },
      '2adults3children': { groceries: 1862, utilities: 541, entertainment: 650, insurance: 390 }
    };

    let loadedBenchmarks = { ...DEFAULT_BENCHMARKS_DATA };
    let selectedHousehold = '2adults2children';

    // Load benchmarks from R2 settings
    async function loadBenchmarksFromSettings() {
      try {
        const settings = await r2Get<{ benchmarks?: typeof DEFAULT_BENCHMARKS_DATA; defaultHousehold?: string }>('settings.json');
        if (settings?.benchmarks) {
          loadedBenchmarks = { ...DEFAULT_BENCHMARKS_DATA, ...settings.benchmarks };
        }
        if (settings?.defaultHousehold) {
          selectedHousehold = settings.defaultHousehold;
          const select = document.getElementById('benchmark-household') as HTMLSelectElement;
          if (select) select.value = selectedHousehold;
        }
      } catch (e) {
        // Use defaults
      }
    }

    // Render benchmark comparison (Output mode)
    function renderBenchmarkComparison() {
      if (!prospect) return;

      const container = document.getElementById('benchmark-comparison');
      const conclusionEl = document.getElementById('benchmark-conclusion');
      if (!container || !conclusionEl) return;

      // Get expense window filtered transactions
      const filteredTxns = getFilteredTransactions();
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);

      // Calculate actual spending by mapped category
      const expenseTxns = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer);

      // Map our categories to benchmark categories (using actual category names from categorize.ts)
      const categoryMapping: Record<string, string> = {
        'Food': 'groceries',
        'Utilities': 'utilities',
        'Entertainment': 'entertainment',
        'Insurance': 'insurance'
      };

      const actualSpending: Record<string, number> = { groceries: 0, utilities: 0, entertainment: 0, insurance: 0 };
      const categoryPresent: Record<string, boolean> = { groceries: false, utilities: false, entertainment: false, insurance: false };

      for (const txn of expenseTxns) {
        const mappedCat = categoryMapping[txn.category];
        if (mappedCat) {
          actualSpending[mappedCat] += Math.abs(txn.amount);
          categoryPresent[mappedCat] = true;
        }
      }

      // Convert to monthly
      Object.keys(actualSpending).forEach(key => {
        actualSpending[key] = actualSpending[key] / windowMonths;
      });

      // Get benchmark for selected household
      const benchmark = loadedBenchmarks[selectedHousehold] || DEFAULT_BENCHMARKS_DATA['2adults2children'];

      // Build comparison cards
      const categories = [
        { key: 'groceries', label: 'Groceries', icon: '🛒' },
        { key: 'utilities', label: 'Utilities', icon: '💡' },
        { key: 'entertainment', label: 'Entertainment', icon: '🎬' },
        { key: 'insurance', label: 'Insurance', icon: '🛡️' }
      ];

      let totalActual = 0;
      let totalBenchmark = 0;
      let categoriesWithData = 0;

      container.innerHTML = categories.map(cat => {
        const actual = actualSpending[cat.key];
        const bench = benchmark[cat.key as keyof typeof benchmark];
        const hasData = categoryPresent[cat.key];
        const diff = actual - bench;
        const pct = bench > 0 ? ((actual / bench) * 100) : 0;

        if (hasData) {
          totalActual += actual;
          totalBenchmark += bench;
          categoriesWithData++;
        }

        const barWidth = Math.min(100, pct);
        const isOver = actual > bench;
        const barColor = !hasData ? 'bg-slate-200' : isOver ? 'bg-rose-400' : 'bg-emerald-400';
        const textColor = !hasData ? 'text-slate-400' : isOver ? 'text-rose-600' : 'text-emerald-600';

        return `
          <div class="bg-white border border-slate-200 rounded-xl p-5 ${!hasData ? 'opacity-60' : ''}">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <span class="text-xl">${cat.icon}</span>
                <span class="font-medium text-slate-700">${cat.label}</span>
              </div>
              ${!hasData ? '<span class="text-xs text-slate-400 bg-slate-100 px-2 py-1 rounded">No data</span>' : ''}
            </div>

            <div class="flex items-end justify-between mb-2">
              <div>
                <p class="text-2xl font-bold ${hasData ? 'text-slate-800' : 'text-slate-400'}">${formatCurrency(actual)}</p>
                <p class="text-xs text-slate-500">Actual / month</p>
              </div>
              <div class="text-right">
                <p class="text-lg font-semibold text-slate-500">${formatCurrency(bench)}</p>
                <p class="text-xs text-slate-400">Benchmark</p>
              </div>
            </div>

            <!-- Progress bar -->
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-2">
              <div class="${barColor} h-full rounded-full transition-all duration-500" style="width: ${barWidth}%"></div>
            </div>

            <p class="text-sm ${textColor} font-medium">
              ${!hasData ? 'No transactions found' :
                isOver ? `${formatCurrency(Math.abs(diff))} over benchmark` :
                `${formatCurrency(Math.abs(diff))} under benchmark`}
            </p>
          </div>
        `;
      }).join('');

      // Render conclusion
      const overallPct = totalBenchmark > 0 ? (totalActual / totalBenchmark) * 100 : 0;
      const isOverall = totalActual > totalBenchmark;

      let conclusionClass, conclusionIcon, conclusionTitle, conclusionText;

      if (categoriesWithData === 0) {
        conclusionClass = 'bg-slate-50 border-slate-200';
        conclusionIcon = '📊';
        conclusionTitle = 'Insufficient Data';
        conclusionText = 'No matching expense categories found in the uploaded statements. Upload more statements or check transaction categorisation.';
      } else if (overallPct < 80) {
        conclusionClass = 'bg-emerald-50 border-emerald-200';
        conclusionIcon = '✅';
        conclusionTitle = 'Below Average Spender';
        conclusionText = `Based on ${categoriesWithData} tracked categories, spending is ${(100 - overallPct).toFixed(0)}% below the NZ benchmark. This suggests conservative spending habits, though some expenses may not be captured in these statements.`;
      } else if (overallPct <= 120) {
        conclusionClass = 'bg-blue-50 border-blue-200';
        conclusionIcon = '📊';
        conclusionTitle = 'Average Spender';
        conclusionText = `Based on ${categoriesWithData} tracked categories, spending is within 20% of the NZ benchmark. This indicates typical spending patterns for a ${selectedHousehold.replace(/(\d)(adult|child)/g, '$1 $2').replace(/children/g, ' children')} household.`;
      } else {
        conclusionClass = 'bg-amber-50 border-amber-200';
        conclusionIcon = '⚠️';
        conclusionTitle = 'Above Average Spender';
        conclusionText = `Based on ${categoriesWithData} tracked categories, spending is ${(overallPct - 100).toFixed(0)}% above the NZ benchmark. Consider reviewing discretionary spending, though some categories may include legitimate business or unusual expenses.`;
      }

      conclusionEl.className = `rounded-xl p-6 mb-6 border ${conclusionClass}`;
      conclusionEl.innerHTML = `
        <div class="flex gap-4">
          <span class="text-3xl">${conclusionIcon}</span>
          <div>
            <h4 class="font-semibold text-slate-800 text-lg mb-1">${conclusionTitle}</h4>
            <p class="text-slate-600">${conclusionText}</p>
            ${categoriesWithData < 4 ? `<p class="text-sm text-slate-500 mt-2"><strong>Note:</strong> Only ${categoriesWithData} of 4 benchmark categories had matching transactions.</p>` : ''}
          </div>
        </div>
      `;
    }

    // Render validation summary (Output mode)
    function renderValidationSummary() {
      if (!prospect) return;

      const overallEl = document.getElementById('validation-overall');
      const checksEl = document.getElementById('validation-checks');
      const missingAccountsEl = document.getElementById('validation-missing-accounts');
      const missingAccountsListEl = document.getElementById('missing-accounts-list');

      if (!overallEl || !checksEl) return;

      const checks: { label: string; status: 'pass' | 'warn' | 'fail'; detail: string; icon: string }[] = [];

      // Get analysis data
      const analysis = analyzeProspect(prospect);
      const filteredTxns = getFilteredTransactions();
      const allTxns = prospect.transactions;

      // Calculate window info
      const windowStartDate = new Date(windowStart);
      const windowEndDate = new Date(windowEnd);
      const windowDays = Math.round((windowEndDate.getTime() - windowStartDate.getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = windowDays / 30;

      // 1. Do we have 3 months of data?
      const dataMonths = analysis.period.months;
      if (dataMonths >= 3) {
        checks.push({
          label: 'Statement Duration',
          status: 'pass',
          detail: `${dataMonths.toFixed(1)} months of data available`,
          icon: '📅'
        });
      } else if (dataMonths >= 2) {
        checks.push({
          label: 'Statement Duration',
          status: 'warn',
          detail: `Only ${dataMonths.toFixed(1)} months - lenders typically require 3 months`,
          icon: '📅'
        });
      } else {
        checks.push({
          label: 'Statement Duration',
          status: 'fail',
          detail: `Only ${dataMonths.toFixed(1)} months - need at least 3 months for most lenders`,
          icon: '📅'
        });
      }

      // 2. Was it recent enough?
      const today = new Date();
      const lastTxnDate = new Date(analysis.period.end);
      const daysSinceLastTxn = Math.round((today.getTime() - lastTxnDate.getTime()) / (1000 * 60 * 60 * 24));

      if (daysSinceLastTxn <= 30) {
        checks.push({
          label: 'Data Recency',
          status: 'pass',
          detail: `Last transaction ${daysSinceLastTxn} days ago`,
          icon: '🕐'
        });
      } else if (daysSinceLastTxn <= 60) {
        checks.push({
          label: 'Data Recency',
          status: 'warn',
          detail: `Last transaction ${daysSinceLastTxn} days ago - may need updated statements`,
          icon: '🕐'
        });
      } else {
        checks.push({
          label: 'Data Recency',
          status: 'fail',
          detail: `Last transaction ${daysSinceLastTxn} days ago - statements are stale`,
          icon: '🕐'
        });
      }

      // 3. Expense window coverage
      const txnsInWindow = filteredTxns.length;
      const expenseTxnsInWindow = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer).length;

      // Check for gaps - are there days with no transactions?
      const txnDates = new Set(filteredTxns.map(t => t.date.split('T')[0]));
      const daysWithTxns = txnDates.size;
      const coveragePercent = Math.round((daysWithTxns / windowDays) * 100);

      if (coveragePercent >= 60) {
        checks.push({
          label: 'Window Coverage',
          status: 'pass',
          detail: `${txnsInWindow} transactions across ${daysWithTxns} days (${coveragePercent}% coverage)`,
          icon: '📊'
        });
      } else if (coveragePercent >= 30) {
        checks.push({
          label: 'Window Coverage',
          status: 'warn',
          detail: `Only ${coveragePercent}% day coverage - possible gaps in statements`,
          icon: '📊'
        });
      } else {
        checks.push({
          label: 'Window Coverage',
          status: 'fail',
          detail: `Low coverage (${coveragePercent}%) - likely missing statements`,
          icon: '📊'
        });
      }

      // 4. Benchmark category coverage
      const categoryMapping: Record<string, string> = {
        'Food': 'groceries',
        'Utilities': 'utilities',
        'Entertainment': 'entertainment',
        'Insurance': 'insurance'
      };

      const expenseTxns = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer);
      const categoriesFound = new Set<string>();
      for (const txn of expenseTxns) {
        const mapped = categoryMapping[txn.category];
        if (mapped) categoriesFound.add(mapped);
      }

      const benchmarkCategories = ['groceries', 'utilities', 'entertainment', 'insurance'];
      const missingCategories = benchmarkCategories.filter(c => !categoriesFound.has(c));

      if (missingCategories.length === 0) {
        checks.push({
          label: 'Benchmark Categories',
          status: 'pass',
          detail: 'All 4 benchmark categories have transaction data',
          icon: '🏷️'
        });
      } else if (missingCategories.length <= 2) {
        checks.push({
          label: 'Benchmark Categories',
          status: 'warn',
          detail: `Missing: ${missingCategories.join(', ')}`,
          icon: '🏷️'
        });
      } else {
        checks.push({
          label: 'Benchmark Categories',
          status: 'fail',
          detail: `Missing ${missingCategories.length} of 4 categories: ${missingCategories.join(', ')}`,
          icon: '🏷️'
        });
      }

      // 5. Account transfer analysis - are we missing linked accounts?
      const transferTxns = allTxns.filter(t => t.isTransfer);
      const transferAccounts = new Map<string, { name: string; moneyIn: number; moneyOut: number; count: number }>();

      for (const txn of transferTxns) {
        // Try to extract account info from description
        const desc = txn.description;
        const key = desc.toLowerCase().replace(/[^a-z0-9]/g, '').substring(0, 30);

        if (!transferAccounts.has(key)) {
          transferAccounts.set(key, { name: desc, moneyIn: 0, moneyOut: 0, count: 0 });
        }
        const acc = transferAccounts.get(key)!;
        if (txn.amount > 0) {
          acc.moneyIn += txn.amount;
        } else {
          acc.moneyOut += Math.abs(txn.amount);
        }
        acc.count++;
      }

      // Check for one-way transfers (money going out but no matching account data)
      const outboundOnlyAccounts = Array.from(transferAccounts.values())
        .filter(a => a.moneyOut > 500 && a.moneyIn === 0);

      if (transferTxns.length === 0) {
        checks.push({
          label: 'Transfer Analysis',
          status: 'pass',
          detail: 'No account transfers marked',
          icon: '🔄'
        });
      } else if (outboundOnlyAccounts.length === 0) {
        checks.push({
          label: 'Transfer Analysis',
          status: 'pass',
          detail: `${transferTxns.length} transfers marked - accounts appear balanced`,
          icon: '🔄'
        });
      } else {
        checks.push({
          label: 'Transfer Analysis',
          status: 'warn',
          detail: `${outboundOnlyAccounts.length} accounts receiving money but not providing statements`,
          icon: '🔄'
        });
      }

      // 6. Associated accounts analysis - which accounts should we request?
      const missingAccounts: { name: string; reason: string; amount: number }[] = [];

      // Check associated accounts that only show as outbound (receiving money from this account)
      for (const acc of analysis.associatedAccounts) {
        // If money is flowing OUT to this account but we have no statement from it
        if (acc.moneyOut > 1000 && acc.moneyOut > acc.moneyIn * 2) {
          missingAccounts.push({
            name: acc.name + (acc.accountNumber ? ` (${acc.accountNumber})` : ''),
            reason: 'Money transferred to this account',
            amount: acc.moneyOut
          });
        }
      }

      // Also flag credit card accounts that might need statements
      const creditCardPatterns = ['visa', 'mastercard', 'credit card', 'amex', 'q card', 'gem'];
      const creditCardTxns = allTxns.filter(t =>
        creditCardPatterns.some(p => t.description.toLowerCase().includes(p)) && t.amount < 0
      );
      const totalCreditCardPayments = creditCardTxns.reduce((sum, t) => sum + Math.abs(t.amount), 0);

      if (totalCreditCardPayments > 500) {
        missingAccounts.push({
          name: 'Credit Card Statement(s)',
          reason: 'Regular credit card payments detected',
          amount: totalCreditCardPayments
        });
      }

      // Render overall status
      const passCount = checks.filter(c => c.status === 'pass').length;
      const warnCount = checks.filter(c => c.status === 'warn').length;
      const failCount = checks.filter(c => c.status === 'fail').length;

      let overallStatus: 'ready' | 'review' | 'incomplete';
      let overallClass: string;
      let overallIcon: string;
      let overallTitle: string;
      let overallText: string;

      if (failCount === 0 && warnCount === 0) {
        overallStatus = 'ready';
        overallClass = 'bg-emerald-50 border-emerald-200';
        overallIcon = '✅';
        overallTitle = 'Data Looks Complete';
        overallText = 'All validation checks passed. Data appears ready for lender submission.';
      } else if (failCount === 0) {
        overallStatus = 'review';
        overallClass = 'bg-amber-50 border-amber-200';
        overallIcon = '⚠️';
        overallTitle = 'Review Recommended';
        overallText = `${warnCount} item${warnCount > 1 ? 's' : ''} may need attention before submission.`;
      } else {
        overallStatus = 'incomplete';
        overallClass = 'bg-rose-50 border-rose-200';
        overallIcon = '❌';
        overallTitle = 'Data Incomplete';
        overallText = `${failCount} critical issue${failCount > 1 ? 's' : ''} found. Additional statements likely required.`;
      }

      overallEl.innerHTML = `
        <div class="rounded-xl p-5 border ${overallClass}">
          <div class="flex gap-4">
            <span class="text-3xl">${overallIcon}</span>
            <div>
              <h4 class="font-semibold text-slate-800 text-lg mb-1">${overallTitle}</h4>
              <p class="text-slate-600">${overallText}</p>
            </div>
          </div>
        </div>
      `;

      // Render checks
      checksEl.innerHTML = checks.map(check => {
        let statusClass: string;
        let statusIcon: string;

        if (check.status === 'pass') {
          statusClass = 'bg-emerald-50 border-emerald-200';
          statusIcon = '<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
        } else if (check.status === 'warn') {
          statusClass = 'bg-amber-50 border-amber-200';
          statusIcon = '<svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>';
        } else {
          statusClass = 'bg-rose-50 border-rose-200';
          statusIcon = '<svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
        }

        return `
          <div class="flex items-start gap-4 p-4 rounded-lg border ${statusClass}">
            <span class="text-xl">${check.icon}</span>
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <h4 class="font-medium text-slate-800">${check.label}</h4>
                ${statusIcon}
              </div>
              <p class="text-sm text-slate-600 mt-1">${check.detail}</p>
            </div>
          </div>
        `;
      }).join('');

      // Render missing accounts
      if (missingAccounts.length > 0 && missingAccountsEl && missingAccountsListEl) {
        missingAccountsEl.classList.remove('hidden');
        missingAccountsListEl.innerHTML = missingAccounts.map(acc => `
          <div class="flex items-center justify-between p-3 bg-amber-50 border border-amber-200 rounded-lg">
            <div>
              <p class="font-medium text-slate-800">${acc.name}</p>
              <p class="text-sm text-slate-500">${acc.reason}</p>
            </div>
            <span class="text-amber-700 font-medium">$${acc.amount.toLocaleString()}</span>
          </div>
        `).join('');
      } else if (missingAccountsEl) {
        missingAccountsEl.classList.add('hidden');
      }
    }

    // Benchmark household selector
    document.getElementById('benchmark-household')?.addEventListener('change', (e) => {
      selectedHousehold = (e.target as HTMLSelectElement).value;
      renderBenchmarkComparison();
    });

    // Render application summary (Output mode)
    function renderApplicationSummary() {
      if (!prospect) return;

      const analysis = analyzeProspect(prospect);
      const container = document.getElementById('application-summary-content');

      if (!container) return;

      const months = analysis.period.months;
      const periodStr = `${formatDate(analysis.period.start)} to ${formatDate(analysis.period.end)}`;

      // Use expense window filtered data (same as pie chart)
      const filteredTxns = getFilteredTransactions();
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);

      // Calculate expenses from filtered transactions (excluding transfers)
      const expenseTxns = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer);
      const totalExpenses = expenseTxns.reduce((sum, t) => sum + Math.abs(t.amount), 0);
      const avgMonthlyExpenses = totalExpenses / windowMonths;

      // Build expense window period string
      const windowPeriodStr = `${formatDate(windowStart)} to ${formatDate(windowEnd)}`;

      // Build narrative summary
      let summary = `APPLICANT EXPENSE SUMMARY\n`;
      summary += `=========================\n\n`;
      summary += `Applicant: ${prospect.name}\n`;
      summary += `Analysis Period: ${windowPeriodStr} (${windowMonths.toFixed(1)} months)\n\n`;

      summary += `MONTHLY EXPENSES\n`;
      summary += `----------------\n`;
      summary += `Average Monthly Expenses: ${formatCurrency(avgMonthlyExpenses)}\n\n`;

      // Build categories from filtered transactions
      const categoryMap = new Map<string, number>();
      for (const txn of expenseTxns) {
        const cat = txn.category || 'Uncategorised';
        categoryMap.set(cat, (categoryMap.get(cat) || 0) + Math.abs(txn.amount));
      }

      // Top spending categories
      const topCategories = Array.from(categoryMap.entries())
        .map(([category, total]) => ({
          category,
          monthlyAverage: total / windowMonths,
          benchmarkStatus: getBenchmarkStatusLocal(category, total / windowMonths)
        }))
        .filter(c => c.monthlyAverage > 0)
        .sort((a, b) => b.monthlyAverage - a.monthlyAverage)
        .slice(0, 6);

      if (topCategories.length > 0) {
        summary += `Top Spending Categories:\n`;
        for (const cat of topCategories) {
          const status = cat.benchmarkStatus === 'above' ? ' (above avg)' :
                        cat.benchmarkStatus === 'below' ? ' (below avg)' : '';
          summary += `  • ${cat.category}: ${formatCurrency(cat.monthlyAverage)}/month${status}\n`;
        }
        summary += `\n`;
      }

      // Key indicators
      summary += `KEY INDICATORS\n`;
      summary += `--------------\n`;
      if (analysis.keyIndicators.gambling.total > 0) {
        summary += `⚠ Gambling: ${formatCurrency(analysis.keyIndicators.gambling.monthly)}/month (${analysis.keyIndicators.gambling.count} transactions)\n`;
      }
      if (analysis.keyIndicators.dishonours.count > 0) {
        summary += `⚠ Dishonours/Returns: ${analysis.keyIndicators.dishonours.count} transactions\n`;
      }
      if (analysis.keyIndicators.debtRepayment.total > 0) {
        summary += `Debt Repayments: ${formatCurrency(analysis.keyIndicators.debtRepayment.monthly)}/month\n`;
      }
      if (analysis.keyIndicators.atmWithdrawals.total > 0) {
        summary += `ATM Withdrawals: ${formatCurrency(analysis.keyIndicators.atmWithdrawals.monthly)}/month\n`;
      }

      // Anomalies/attention items
      const highSeverity = analysis.anomalies.filter(a => a.severity === 'high');
      if (highSeverity.length > 0) {
        summary += `\nATTENTION ITEMS\n`;
        summary += `---------------\n`;
        for (const a of highSeverity.slice(0, 5)) {
          summary += `• ${a.description}\n`;
        }
      }

      summary += `\n---\n`;
      summary += `Generated by Approved | ${new Date().toLocaleDateString('en-NZ')}\n`;

      container.textContent = summary;

      // Copy to clipboard handler
      document.getElementById('copy-summary')?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(summary);
          const btn = document.getElementById('copy-summary');
          if (btn) {
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Copied!';
            setTimeout(() => { btn.innerHTML = originalHTML; }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });

      // Refresh button - regenerate summary
      document.getElementById('refresh-summary')?.addEventListener('click', () => {
        const btn = document.getElementById('refresh-summary');
        if (btn) {
          btn.classList.add('animate-spin');
          setTimeout(() => {
            renderApplicationSummary();
            btn.classList.remove('animate-spin');
          }, 300);
        }
      });
    }

    // Render log
    function renderLog() {
