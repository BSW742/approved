                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <p class="text-sm font-medium text-slate-800 truncate">${item.txn.description}</p>
                    <span class="text-xs text-slate-400 whitespace-nowrap">${actionDate}</span>
                  </div>
                  <p class="text-sm text-purple-700 mt-1">"${item.txn.note}"</p>
                  <p class="text-xs text-slate-500 mt-1">${formatDate(item.txn.date)} • ${formatCurrency(Math.abs(item.txn.amount))}</p>
                </div>
              </div>
            `;
          } else {
            return `
              <div class="flex items-start gap-3 p-3 bg-indigo-50 border border-indigo-100 rounded-lg">
                <svg class="w-5 h-5 text-indigo-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <p class="text-sm font-medium text-slate-800 truncate">${item.txn.description}</p>
                    <span class="text-xs text-slate-400 whitespace-nowrap">${actionDate}</span>
                  </div>
                  <p class="text-sm text-indigo-700 mt-1">Marked as account transfer</p>
                  <p class="text-xs text-slate-500 mt-1">${formatDate(item.txn.date)} • ${formatCurrency(Math.abs(item.txn.amount))}</p>
                </div>
              </div>
