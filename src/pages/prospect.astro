        toggleIcon?.classList.add('rotate-180');
      } else {
        hiddenSection?.classList.add('hidden');
        const count = hiddenSection?.children.length || 0;
        if (toggleText) toggleText.textContent = `Show ${count} more (< $1,000)`;
        toggleIcon?.classList.remove('rotate-180');
      }
    });

    // PDF Upload handling
    document.querySelectorAll('#pdf-upload, .pdf-upload-trigger').forEach(input => {
      input.addEventListener('change', async (e) => {
        const files = (e.target as HTMLInputElement).files;
        if (!files || files.length === 0 || !prospect) return;

        const progressEl = document.getElementById('upload-progress');
        const statusEl = document.getElementById('upload-status');
        const detailEl = document.getElementById('upload-detail');
        const countEl = document.getElementById('upload-count');
        const progressFill = document.getElementById('upload-progress-fill');

        progressEl?.classList.remove('hidden');
        const fileArray = Array.from(files);
        const total = fileArray.length;
        let processed = 0;
        let totalTxns = 0;

        for (const file of fileArray) {
          processed++;
          if (statusEl) statusEl.textContent = `Processing ${file.name}`;
          if (detailEl) detailEl.textContent = 'Reading PDF...';
          if (countEl) countEl.textContent = `${processed} of ${total}`;
          if (progressFill) progressFill.style.width = `${(processed / total) * 100}%`;

          const txnCount = await processPDF(file, (stage: string) => {
            if (detailEl) detailEl.textContent = stage;
          });
          totalTxns += txnCount;
        }

        console.log('Upload complete. Total transactions:', totalTxns, 'Prospect transactions:', prospect.transactions.length);

        if (totalTxns > 0) {
          if (statusEl) statusEl.textContent = 'Complete!';
          if (detailEl) detailEl.textContent = `Imported ${totalTxns} transactions from ${total} file${total > 1 ? 's' : ''}`;
        } else {
          if (statusEl) statusEl.textContent = 'No transactions found';
          if (detailEl) detailEl.textContent = `Could not extract transactions from ${total} file${total > 1 ? 's' : ''}. Check the PDF format.`;
        }

        // Show validation warnings if any
        if (lastUploadValidation && lastUploadValidation.warnings.length > 0) {
          showValidationWarnings(lastUploadValidation);
        }

        // Keep visible longer if no transactions or warnings
        const hasWarnings = lastUploadValidation?.warnings.length ?? 0 > 0;
        setTimeout(() => {
          progressEl?.classList.add('hidden');
          if (progressFill) progressFill.style.width = '0%';
        }, totalTxns > 0 && !hasWarnings ? 1500 : 3000);

        (e.target as HTMLInputElement).value = '';
        renderAnalysis();
        console.log('After renderAnalysis. Prospect:', prospect);
      });
    });

    async function processPDF(file: File, onProgress?: (stage: string) => void): Promise<number> {
      if (!prospect) return 0;

      try {
        console.log('Processing PDF:', file.name);
        onProgress?.('Loading file...');
        const arrayBuffer = await file.arrayBuffer();
        console.log('Got array buffer, size:', arrayBuffer.byteLength);

        // Clone the ArrayBuffer before PDF.js uses it (PDF.js may detach the original)
        const arrayBufferCopy = arrayBuffer.slice(0);

        // Generate document ID upfront
        const documentId = generateId();

        onProgress?.('Opening PDF...');
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        console.log('PDF loaded, pages:', pdf.numPages);

        let fullText = '';
        const pageTexts: PageText[] = [];

        for (let i = 1; i <= pdf.numPages; i++) {
          onProgress?.(`Extracting page ${i} of ${pdf.numPages}...`);
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();

          // Extract text with position data and reconstruct rows properly
          const items = textContent.items.map((item: any) => ({
            str: item.str,
            x: item.transform[4],  // x position
            y: item.transform[5],  // y position
          }));

          // Group items by y-coordinate (same row = similar y value, within 3px tolerance)
          const rows: Map<number, typeof items> = new Map();
          for (const item of items) {
            // Find existing row with similar y
            let foundRow = false;
            for (const [rowY, rowItems] of rows) {
              if (Math.abs(rowY - item.y) < 3) {
                rowItems.push(item);
                foundRow = true;
                break;
              }
            }
            if (!foundRow) {
              rows.set(item.y, [item]);
            }
          }

          // Sort rows by y (descending - PDF coordinates start from bottom)
          const sortedRows = Array.from(rows.entries())
            .sort((a, b) => b[0] - a[0]);

          // Build page text by sorting each row's items by x and joining
          const pageText = sortedRows.map(([, rowItems]) => {
            // Sort items in row by x position (left to right)
            rowItems.sort((a, b) => a.x - b.x);
            return rowItems.map(item => item.str).join(' ');
          }).join('\n');

          fullText += pageText + '\n';
          pageTexts.push({ pageNumber: i, text: pageText });
        }
        console.log('Text extracted, length:', fullText.length);

        // Save PDF to IndexedDB with text content for searching (local cache)
        onProgress?.('Saving document...');
        await savePDF(documentId, arrayBufferCopy, pageTexts);

        // Also save to R2 for cloud sync
        try {
          await r2SavePDF(prospectId, documentId, arrayBufferCopy);
        } catch (e) {
          console.warn('Failed to save PDF to R2:', e);
        }

        onProgress?.('Detecting bank format...');
        const bank = detectBank(fullText);
        console.log('Detected bank:', bank);

        onProgress?.('Parsing transactions...');
        let result;

        switch (bank) {
          case 'ANZ':
            result = parseANZStatement(fullText, file.name, documentId, pageTexts);
            break;
          case 'ASB':
            result = parseASBStatement(fullText, file.name, documentId, pageTexts);
            break;
          case 'Westpac':
            result = parseWestpacStatement(fullText, file.name, documentId, pageTexts);
            break;
          default:
            result = parseGenericStatement(fullText, file.name, bank, documentId, pageTexts);
        }

        // Override the document ID with our pre-generated one
        result.document.id = documentId;

        console.log('Parsed result:', {
          transactions: result.transactions.length,
          accounts: result.accounts.length,
          document: result.document
        });

        // === VALIDATION CHECKS ===
        const validation = {
          pageCount: pdf.numPages,
          txnCount: result.transactions.length,
          txnPerPage: result.transactions.length / pdf.numPages,
          warnings: [] as string[],
          statementPeriod: { start: result.document.periodStart, end: result.document.periodEnd },
          rawTextSample: fullText.substring(0, 2000),
        };

        // Check 1: Transactions per page (expect ~10-30 per page for statements)
        if (validation.txnPerPage < 3) {
          validation.warnings.push(`Low extraction: Only ${validation.txnCount} transactions from ${validation.pageCount} pages (${validation.txnPerPage.toFixed(1)}/page). Expected 10-30/page.`);
        }

        // Check 2: Zero transactions
        if (result.transactions.length === 0) {
          validation.warnings.push('No transactions extracted. PDF format may not be supported or text extraction failed.');
          console.warn('No transactions parsed! First 2000 chars of text:', fullText.substring(0, 2000));
        } else {
          console.log('Sample transactions:', result.transactions.slice(0, 3));
        }

        // Store validation for display
        lastUploadValidation = validation;
        console.log('Validation:', validation);

        // Merge transactions
        prospect.transactions = mergeTransactions(prospect.transactions, result.transactions);

        // Add accounts (avoid duplicates)
        for (const account of result.accounts) {
          if (!prospect.accounts.find(a => a.number === account.number)) {
            prospect.accounts.push(account);
          }
        }

        // Add document
        result.document.pageCount = pdf.numPages;
        prospect.documents.push(result.document);

        await r2SaveProspect(prospect);
        return result.transactions.length;

      } catch (error: any) {
        console.error('Error processing PDF:', error);
        console.error('Error stack:', error?.stack);
        console.error('Error message:', error?.message);

        // If it's a deserialization error, clear corrupted IndexedDB data
        if (error?.message?.includes('deserialize')) {
          console.log('Clearing corrupted IndexedDB data...');
          try {
            await clearAllPDFs();
            alert(`Database cleared. Please try uploading ${file.name} again.`);
          } catch (e) {
            console.error('Error clearing database:', e);
            alert(`Error processing ${file.name}. Please clear your browser data and try again.`);
          }
        } else {
          alert(`Error processing ${file.name}: ${error?.message || 'Unknown error'}. Check console for details.`);
        }
        return 0;
      }
    }

    function renderAnalysis() {
      if (!prospect) return;

      // Update header
      document.getElementById('prospect-name')!.textContent = prospect.name;

      if (prospect.transactions.length === 0) {
        document.getElementById('no-data')?.classList.remove('hidden');
        document.getElementById('analysis-content')?.classList.add('hidden');
        document.getElementById('prospect-period')!.textContent = 'No statements uploaded';
        return;
      }

      document.getElementById('no-data')?.classList.add('hidden');
      document.getElementById('analysis-content')?.classList.remove('hidden');

      // Initialize expense window if not set
      if (!windowStart || !windowEnd) {
        const defaultWindow = getDefault3MonthWindow();
        windowStart = defaultWindow.start;
        windowEnd = defaultWindow.end;
        if (windowStartInput) windowStartInput.value = windowStart;
        if (windowEndInput) windowEndInput.value = windowEnd;
      }

      // Get filtered transactions for expense window
      const filteredTxns = getFilteredTransactions();

      // Calculate totals for filtered transactions (exclude transfers from expenses)
      const moneyIn = filteredTxns.filter(t => t.amount > 0 && !t.isTransfer).reduce((sum, t) => sum + t.amount, 0);
      const moneyOut = filteredTxns.filter(t => t.amount < 0 && !t.isTransfer).reduce((sum, t) => sum + Math.abs(t.amount), 0);
      const expenseTxnCount = filteredTxns.filter(t => !t.isTransfer).length;

      const analysis = analyzeProspect(prospect);

      // Update period display to show expense window
      const startDisplay = new Date(windowStart).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
      const endDisplay = new Date(windowEnd).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
      document.getElementById('prospect-period')!.textContent = `${startDisplay} - ${endDisplay}`;

      // Summary cards - use filtered values
      document.getElementById('total-in')!.textContent = formatCurrency(moneyIn);

      // Calculate months in window for averages
      const windowDays = Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1;
      const windowMonths = Math.max(1, windowDays / 30);
      document.getElementById('monthly-in')!.textContent = `${formatCurrency(moneyIn / windowMonths)}/month avg`;

      const net = moneyIn - moneyOut;
      const netEl = document.getElementById('net-position')!;
      netEl.textContent = formatCurrency(net, true);
      netEl.className = `text-2xl font-bold ${net >= 0 ? 'text-emerald-600' : 'text-rose-600'}`;
      document.getElementById('net-monthly')!.textContent = `${formatCurrency(net / windowMonths, true)}/month avg`;

      document.getElementById('doc-count')!.textContent = prospect.documents.length.toString();
      document.getElementById('txn-count')!.textContent = `${expenseTxnCount} txns`;

      // Money In section
      document.getElementById('salary-total')!.textContent = formatCurrency(analysis.moneyInSummary.salary.total);
      document.getElementById('salary-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.salary.monthly)}/mo)`;
      document.getElementById('govt-total')!.textContent = formatCurrency(analysis.moneyInSummary.governmentSupport.total);
      document.getElementById('govt-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.governmentSupport.monthly)}/mo)`;
      document.getElementById('other-in-total')!.textContent = formatCurrency(analysis.moneyInSummary.otherMoneyIn.total);
      document.getElementById('other-in-monthly')!.textContent = `(${formatCurrency(analysis.moneyInSummary.otherMoneyIn.monthly)}/mo)`;

      // Key Indicators
      const indicators = [
        { name: 'ATM Withdrawals', data: analysis.keyIndicators.atmWithdrawals },
        { name: 'Debt Repayment', data: analysis.keyIndicators.debtRepayment },
        { name: 'Dishonours', data: analysis.keyIndicators.dishonours, isWarning: true },
        { name: 'Fees', data: analysis.keyIndicators.fees },
        { name: 'Gambling', data: analysis.keyIndicators.gambling, isWarning: true },
      ];

      document.getElementById('key-indicators')!.innerHTML = indicators.map(ind => `
        <div class="flex justify-between items-center py-2 border-b border-slate-100 ${ind.isWarning && ind.data.count > 0 ? 'bg-rose-50 -mx-2 px-2 rounded' : ''}">
          <span class="text-slate-600 ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700 font-medium' : ''}">${ind.name}</span>
          <div class="text-right">
            <span class="font-medium ${ind.isWarning && ind.data.count > 0 ? 'text-rose-700' : 'text-slate-700'}">${ind.data.count}</span>
            <span class="text-xs text-slate-400 ml-2">${formatCurrency(ind.data.total)}</span>
          </div>
        </div>
      `).join('');

      // Associated Accounts
      const significantAccounts = analysis.associatedAccounts.filter(a => a.totalAmount >= 1000);
      const minorAccounts = analysis.associatedAccounts.filter(a => a.totalAmount < 1000);

      if (analysis.associatedAccounts.length > 0) {
        document.getElementById('no-accounts')?.classList.add('hidden');

        const renderAccountRow = (acc: typeof analysis.associatedAccounts[0]) => `
          <div class="flex items-center justify-between py-3 px-4 bg-slate-50 rounded-lg border border-slate-100 hover:border-blue-200 transition-colors">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span class="font-medium text-slate-800 truncate">${acc.name}</span>
              ${acc.accountNumber ? `<span class="text-slate-500 font-mono">${acc.accountNumber}</span>` : ''}
            </div>
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-4">
                ${acc.moneyIn > 0 ? `<span class="assoc-income text-emerald-600 font-medium">+${formatCurrency(acc.moneyIn)}</span>` : ''}
                ${acc.moneyOut > 0 ? `<span class="text-rose-600 font-medium">-${formatCurrency(acc.moneyOut)}</span>` : ''}
              </div>
              <span class="text-slate-400 w-16 text-right">${acc.transactionCount} txn${acc.transactionCount !== 1 ? 's' : ''}</span>
            </div>
          </div>
        `;

        document.getElementById('associated-accounts-list')!.innerHTML = significantAccounts.map(renderAccountRow).join('');

        if (minorAccounts.length > 0) {
          document.getElementById('associated-accounts-hidden')!.innerHTML = minorAccounts.map(renderAccountRow).join('');
          document.getElementById('toggle-associated')!.classList.remove('hidden');
          (document.getElementById('toggle-associated-text') as HTMLElement).textContent = `Show ${minorAccounts.length} more (< $1,000)`;
        } else {
          document.getElementById('toggle-associated')!.classList.add('hidden');
        }
      } else {
        document.getElementById('no-accounts')?.classList.remove('hidden');
        document.getElementById('associated-accounts-list')!.innerHTML = '';
        document.getElementById('toggle-associated')!.classList.add('hidden');
      }

      // Attention items
      renderAttention(analysis);

      // Categories
      renderCategories(analysis);

      // Transactions
      renderTransactions();

      // Documents
      renderDocuments();

      // Transfers
      renderTransfers();

      // Log
      renderLog();

      // Output mode renders
      renderValidationSummary();
      renderAverageExpense();
      renderBenchmarkComparison();

      // Reapply expenses filter after rendering
      applyExpensesFilter();
    }

    function renderCategories(analysis: ReturnType<typeof analyzeProspect>) {
      const grid = document.getElementById('categories-grid')!;

      // Get month-filtered transactions
      const filteredTxns = getFilteredTransactions();

      // Build categories from filtered transactions
      const categoryMap = new Map<string, { total: number; count: number; transactions: typeof filteredTxns }>();

      for (const txn of filteredTxns) {
        // Use "Account Transfers" category for transfers, otherwise use original category
        const catName = txn.isTransfer ? 'Account Transfers' : txn.category;

        // Skip income transactions if expenses only mode (but include transfers)
        if (expensesOnly && !txn.isTransfer && txn.amount > 0) continue;

        if (!categoryMap.has(catName)) {
          categoryMap.set(catName, { total: 0, count: 0, transactions: [] });
        }
        const cat = categoryMap.get(catName)!;
        cat.total += Math.abs(txn.amount);
        cat.count++;
        cat.transactions.push(txn);
      }

      // Convert to array and sort by total
      const categories = Array.from(categoryMap.entries())
        .map(([name, data]) => ({
          category: name,
          total: data.total,
          transactionCount: data.count,
          transactions: data.transactions
        }))
        .filter(c => c.transactionCount > 0)
        .sort((a, b) => b.total - a.total);

      // Add color for Account Transfers
      const TRANSFER_COLOR = '#6366f1'; // Indigo

      grid.innerHTML = categories.map(cat => {
        const color = cat.category === 'Account Transfers' ? TRANSFER_COLOR : (CATEGORY_COLORS[cat.category] || '#94a3b8');
        const benchmark = BENCHMARKS[cat.category];
        let benchmarkIndicator = '';

        // Calculate window months for averages
        const windowDays = windowStart && windowEnd ?
          Math.round((new Date(windowEnd).getTime() - new Date(windowStart).getTime()) / (1000 * 60 * 60 * 24)) + 1 : 90;
        const windowMonths = Math.max(1, windowDays / 30);
        const monthlyAvg = cat.total / windowMonths;

        if (benchmark && cat.category !== 'Account Transfers') {
          if (monthlyAvg > benchmark.high) {
            benchmarkIndicator = `<span class="text-xs text-rose-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
              Above avg
            </span>`;
          } else if (monthlyAvg < benchmark.low) {
            benchmarkIndicator = `<span class="text-xs text-emerald-500 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Below avg
            </span>`;
          }
        }

        const isTransferCat = cat.category === 'Account Transfers';

        return `
          <button onclick="showCategoryDetail('${cat.category}')" class="bg-slate-50 hover:bg-slate-100 rounded-lg p-4 text-left transition-colors group ${isTransferCat ? 'border-2 border-dashed border-indigo-200' : ''}">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full" style="background-color: ${color}"></div>
                <span class="font-medium text-slate-700 group-hover:text-emerald-600 transition-colors">${cat.category}</span>
              </div>
              <span class="text-xs text-slate-400">${cat.transactionCount} txns</span>
            </div>
            <div class="flex items-end justify-between">
              <div>
                <p class="text-lg font-semibold ${isTransferCat ? 'text-indigo-600' : 'text-slate-900'}">${formatCurrency(cat.total)}</p>
                <p class="text-xs text-slate-500">${formatCurrency(monthlyAvg)}/month</p>
              </div>
              ${benchmarkIndicator}
            </div>
          </button>
        `;
      }).join('');
    }

    function renderAttention(analysis: ReturnType<typeof analyzeProspect>) {
      if (!prospect) return;

      const transferIds = new Set(prospect.transactions.filter(t => t.isTransfer).map(t => t.id));

      // Get transaction IDs in selected date range
      const filteredTxnIds = new Set(getFilteredTransactions().map(t => t.id));

      const attentionItems = analysis.anomalies
        .filter(a => a.severity === 'high' || a.severity === 'medium')
        .filter(a => !a.transactionId || !transferIds.has(a.transactionId))
        .filter(a => {
          // If no transactionId (category-level anomaly), show it
          if (!a.transactionId) return true;
          // If has transactionId, only show if transaction is in expense window
          return filteredTxnIds.has(a.transactionId);
        });

      if (attentionItems.length > 0) {
        document.getElementById('no-attention')?.classList.add('hidden');
        document.getElementById('attention-list')!.innerHTML = attentionItems.map(a => {
          const txn = a.transactionId ? prospect.transactions.find(t => t.id === a.transactionId) : null;
          return `
            <div class="p-4 bg-amber-50 border border-amber-200 rounded-lg ${txn ? 'cursor-pointer hover:bg-amber-100 transition-colors' : ''}" ${txn ? `onclick="showAttentionTransaction('${a.transactionId}')"` : ''}>
              <div class="flex items-start gap-3">
                <span class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${a.severity === 'high' ? 'bg-rose-500' : 'bg-amber-500'}"></span>
                <div class="flex-1">
                  <p class="text-slate-800">${a.reason}</p>
                  ${a.suggestion ? `<p class="text-amber-600 text-sm mt-1">${a.suggestion}</p>` : ''}
                  ${txn ? `
                    <div class="mt-3 pt-3 border-t border-amber-200">
                      <div class="flex items-center justify-between text-sm">
                        <div>
                          <span class="text-slate-500">${formatDate(txn.date)}</span>
                          <span class="mx-2 text-slate-300">|</span>
                          <span class="text-slate-700">${txn.description}</span>
                        </div>
                        <span class="font-medium ${txn.amount < 0 ? 'text-rose-600' : 'text-emerald-600'}">${formatCurrency(Math.abs(txn.amount))}</span>
                      </div>
                      <p class="text-xs text-slate-400 mt-1">${txn.category} • Click to view options</p>
                    </div>
                  ` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');
      } else {
        document.getElementById('attention-list')!.innerHTML = '';
        document.getElementById('no-attention')?.classList.remove('hidden');
      }
    }

