---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prospects">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Prospects</h1>
      <p class="text-slate-500 mt-1">Manage your mortgage application assessments</p>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16">
      <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-slate-700 mb-2">No prospects yet</h2>
      <p class="text-slate-500 mb-6">Get started by adding your first prospect</p>
      <a href="/new" class="inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-6 py-3 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-md hover:shadow-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add New Prospect
      </a>
    </div>

    <!-- Prospects Grid -->
    <div id="prospects-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <!-- Populated by JS -->
    </div>
  </div>

  <script>
    import { getProspects, deleteProspect } from '../lib/store';
    import { analyzeProspect, formatCurrency } from '../lib/analysis';

    function renderProspects() {
      const prospects = getProspects();
      const grid = document.getElementById('prospects-grid');
      const emptyState = document.getElementById('empty-state');

      if (!grid || !emptyState) return;

      if (prospects.length === 0) {
        grid.classList.add('hidden');
        emptyState.classList.remove('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      grid.classList.remove('hidden');

      grid.innerHTML = prospects.map(prospect => {
        const analysis = analyzeProspect(prospect);
        const hasAnomalies = analysis.anomalies.filter(a => a.severity === 'high').length > 0;

        return `
          <a href="/prospect?id=${prospect.id}" class="group bg-white rounded-xl border border-slate-200 p-6 hover:shadow-lg hover:border-emerald-300 transition-all duration-200 animate-fade-in">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-emerald-100 to-teal-100 rounded-full flex items-center justify-center">
                  <span class="text-lg font-bold text-emerald-600">${prospect.name.charAt(0).toUpperCase()}</span>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 group-hover:text-emerald-600 transition-colors">${prospect.name}</h3>
                  <p class="text-sm text-slate-500">${prospect.documents.length} document${prospect.documents.length !== 1 ? 's' : ''}</p>
                </div>
              </div>
              ${hasAnomalies ? `
                <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-medium rounded-full flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                  Review
                </span>
              ` : ''}
            </div>

            ${prospect.transactions.length > 0 ? `
              <div class="space-y-3">
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">Period</span>
                  <span class="text-slate-700">${analysis.period.months} month${analysis.period.months !== 1 ? 's' : ''}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">Money In</span>
                  <span class="text-emerald-600 font-medium">${formatCurrency(analysis.moneyIn)}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">Money Out</span>
                  <span class="text-rose-600 font-medium">${formatCurrency(analysis.moneyOut)}</span>
                </div>
                <div class="pt-3 border-t border-slate-100">
                  <div class="flex justify-between text-sm">
                    <span class="text-slate-500">Net Position</span>
                    <span class="font-semibold ${analysis.moneyIn - analysis.moneyOut >= 0 ? 'text-emerald-600' : 'text-rose-600'}">
                      ${formatCurrency(analysis.moneyIn - analysis.moneyOut, true)}
                    </span>
                  </div>
                </div>
              </div>
            ` : `
              <div class="text-center py-4">
                <p class="text-sm text-slate-400">No statements uploaded</p>
                <p class="text-xs text-slate-400 mt-1">Click to upload documents</p>
              </div>
            `}

            <div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center">
              <span class="text-xs text-slate-400">
                Updated ${new Date(prospect.updatedAt).toLocaleDateString('en-NZ')}
              </span>
              <button
                onclick="event.preventDefault(); event.stopPropagation(); deleteProspectHandler('${prospect.id}', '${prospect.name}')"
                class="text-slate-400 hover:text-rose-500 transition-colors p-1"
                title="Delete prospect"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </a>
        `;
      }).join('');
    }

    // Make delete handler globally available
    (window as any).deleteProspectHandler = (id: string, name: string) => {
      if (confirm(`Are you sure you want to delete "${name}"? This cannot be undone.`)) {
        deleteProspect(id);
        renderProspects();
      }
    };

    // Initial render
    renderProspects();
  </script>
</Layout>
