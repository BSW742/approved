---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prospects">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Password Gate -->
    <div id="password-gate" class="hidden">
      <div class="max-w-md mx-auto text-center py-16">
        <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-700 mb-2">Enter Password</h2>
        <p class="text-slate-500 mb-6">Access your cloud-synced prospects</p>
        <form id="password-form" class="space-y-4">
          <input
            type="password"
            id="password-input"
            placeholder="Password"
            class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all text-center"
            autocomplete="current-password"
          />
          <p id="password-error" class="hidden text-rose-500 text-sm">Wrong password</p>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-6 py-3 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-md hover:shadow-lg"
          >
            Unlock
          </button>
        </form>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="hidden text-center py-16">
      <div class="animate-spin w-10 h-10 border-4 border-emerald-500 border-t-transparent rounded-full mx-auto mb-4"></div>
      <p class="text-slate-500">Loading prospects...</p>
    </div>

    <!-- Main Content (hidden until authenticated) -->
    <div id="main-content" class="hidden">
      <!-- Header -->
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-slate-900">Prospects</h1>
          <p class="text-slate-500 mt-1">Manage your mortgage application assessments</p>
        </div>
        <div class="flex items-center gap-3">
          <span id="sync-status" class="text-xs text-emerald-600 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <circle cx="10" cy="10" r="4" />
            </svg>
            Cloud synced
          </span>
          <button
            id="logout-btn"
            class="text-slate-400 hover:text-slate-600 transition-colors p-2"
            title="Sign out"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-16">
        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-700 mb-2">No prospects yet</h2>
        <p class="text-slate-500 mb-6">Get started by adding your first prospect</p>
        <a href="/new" class="inline-flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 text-white px-6 py-3 rounded-lg font-medium hover:from-emerald-600 hover:to-teal-600 transition-all shadow-md hover:shadow-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add New Prospect
        </a>
      </div>

      <!-- Prospects Grid -->
      <div id="prospects-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <!-- Populated by JS -->
      </div>

      <!-- Add New Button (floating) -->
      <a
        href="/new"
        id="add-new-btn"
        class="hidden fixed bottom-8 right-8 w-14 h-14 bg-gradient-to-r from-emerald-500 to-teal-500 text-white rounded-full shadow-lg hover:shadow-xl hover:from-emerald-600 hover:to-teal-600 transition-all flex items-center justify-center"
        title="Add new prospect"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
      </a>
    </div>
  </div>

  <script>
    import { r2GetProspectsList, r2DeleteProspect, type ProspectListItem } from '../lib/store';
    import { hasPassword, setPassword, clearPassword, validatePassword } from '../lib/r2';

    const passwordGate = document.getElementById('password-gate');
    const loadingState = document.getElementById('loading-state');
    const mainContent = document.getElementById('main-content');
    const passwordForm = document.getElementById('password-form');
    const passwordInput = document.getElementById('password-input') as HTMLInputElement;
    const passwordError = document.getElementById('password-error');
    const logoutBtn = document.getElementById('logout-btn');
    const grid = document.getElementById('prospects-grid');
    const emptyState = document.getElementById('empty-state');
    const addNewBtn = document.getElementById('add-new-btn');

    // Check if already authenticated
    async function init() {
      if (hasPassword()) {
        showLoading();
        await loadProspects();
      } else {
        showPasswordGate();
      }
    }

    function showPasswordGate() {
      passwordGate?.classList.remove('hidden');
      loadingState?.classList.add('hidden');
      mainContent?.classList.add('hidden');
      passwordInput?.focus();
    }

    function showLoading() {
      passwordGate?.classList.add('hidden');
      loadingState?.classList.remove('hidden');
      mainContent?.classList.add('hidden');
    }

    function showMainContent() {
      passwordGate?.classList.add('hidden');
      loadingState?.classList.add('hidden');
      mainContent?.classList.remove('hidden');
    }

    // Handle password form submission
    passwordForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw = passwordInput?.value || '';

      if (!pw) return;

      passwordError?.classList.add('hidden');

      const valid = await validatePassword(pw);

      if (valid) {
        showLoading();
        await loadProspects();
      } else {
        passwordError?.classList.remove('hidden');
        passwordInput?.focus();
        passwordInput?.select();
      }
    });

    // Handle logout
    logoutBtn?.addEventListener('click', () => {
      clearPassword();
      showPasswordGate();
    });

    // Load prospects from R2
    async function loadProspects() {
      try {
        const prospects = await r2GetProspectsList();
        renderProspects(prospects);
        showMainContent();
      } catch (e) {
        console.error('Failed to load prospects:', e);
        // If auth failed, show password gate
        if ((e as Error).message === 'Unauthorized') {
          clearPassword();
          showPasswordGate();
        } else {
          // Show empty state on other errors
          renderProspects([]);
          showMainContent();
        }
      }
    }

    function renderProspects(prospects: ProspectListItem[]) {
      if (!grid || !emptyState) return;

      if (prospects.length === 0) {
        grid.classList.add('hidden');
        emptyState.classList.remove('hidden');
        addNewBtn?.classList.add('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      grid.classList.remove('hidden');
      addNewBtn?.classList.remove('hidden');

      grid.innerHTML = prospects.map(prospect => {
        return `
          <a href="/prospect?id=${prospect.id}" class="group bg-white rounded-xl border border-slate-200 p-6 hover:shadow-lg hover:border-emerald-300 transition-all duration-200 animate-fade-in">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-emerald-100 to-teal-100 rounded-full flex items-center justify-center">
                  <span class="text-lg font-bold text-emerald-600">${prospect.name.charAt(0).toUpperCase()}</span>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 group-hover:text-emerald-600 transition-colors">${prospect.name}</h3>
                  <p class="text-sm text-slate-500">${prospect.documentCount} document${prospect.documentCount !== 1 ? 's' : ''}</p>
                </div>
              </div>
            </div>

            ${prospect.transactionCount > 0 ? `
              <div class="space-y-3">
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">Transactions</span>
                  <span class="text-slate-700">${prospect.transactionCount}</span>
                </div>
              </div>
            ` : `
              <div class="text-center py-4">
                <p class="text-sm text-slate-400">No statements uploaded</p>
                <p class="text-xs text-slate-400 mt-1">Click to upload documents</p>
              </div>
            `}

            <div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center">
              <span class="text-xs text-slate-400">
                Updated ${new Date(prospect.updatedAt).toLocaleDateString('en-NZ')}
              </span>
              <button
                onclick="event.preventDefault(); event.stopPropagation(); deleteProspectHandler('${prospect.id}', '${prospect.name}')"
                class="text-slate-400 hover:text-rose-500 transition-colors p-1"
                title="Delete prospect"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </a>
        `;
      }).join('');
    }

    // Make delete handler globally available
    (window as any).deleteProspectHandler = async (id: string, name: string) => {
      if (confirm(`Are you sure you want to delete "${name}"? This cannot be undone.`)) {
        try {
          await r2DeleteProspect(id);
          await loadProspects();
        } catch (e) {
          console.error('Failed to delete:', e);
          alert('Failed to delete prospect');
        }
      }
    };

    // Initialize
    init();
  </script>
</Layout>
